<https://nova.org.za/novaimpactaccountingstandard/document-schema/MonitoringReport-6.0.0>
    a nias-o:DocumentSchema ;
    dcterms:title "Monitoring Report 6.0.0"@en ;
    sh:targetClass nias-o:MonitoringReport ;
    nias-o:validatingShape nias-o:MonitoringReportShape .

<https://nova.org.za/novaimpactaccountingstandard/document-schema/GenericDocumentReview-5.0.0>
    a nias-o:DocumentSchema ;
    dcterms:title "Generic Document Review 5.0.0"@en ;
    sh:targetClass nias-o:GenericDocumentReview ;
