@prefix aiao: <http://w3id.org/aiao#> .
@prefix claimont: <http://w3id.org/claimont#> .
@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix impactont: <http://w3id.org/impactont#> .
@prefix meth: <http://independentimpact.org/methodology/> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ---------------------------------------------------------------------------
# Example: Valid monitoring impact report wrapper (Phase 6)
# ---------------------------------------------------------------------------

<https://nova.org.za/novaimpactaccountingstandard/projects/project-alpha>
    a aiao:Project .

<https://nova.org.za/novaimpactaccountingstandard/users/agent-001>
    a nias-o:PlatformUser .

<https://nova.org.za/novaimpactaccountingstandard/methodologies/NIAS-SOLAR-001>
    a meth:Methodology .

<https://nova.org.za/novaimpactaccountingstandard/documents/source-metered-energy>
    a data:Document,
        dcterms:Resource ;
    nias-o:resourceIpfsUri "ipfs://bafybeic4mqxl2aev77d76xstbt2ah2u2l7vt5ahx2hzk5c7i3kj2g5t7ma"^^xsd:anyURI .

<https://nova.org.za/novaimpactaccountingstandard/attestations/mr-attestation-001>
    a claimont:Attestation ;
    claimont:hasSubject <https://nova.org.za/novaimpactaccountingstandard/claims/impact-claim-alpha-monitoring-01> .

<https://nova.org.za/novaimpactaccountingstandard/reports/mr-alpha-2026-q1>
    a nias-o:MonitoringImpactReport ;
    claimont:isMadeBy <https://nova.org.za/novaimpactaccountingstandard/users/agent-001> ;
    claimont:hasSubject <https://nova.org.za/novaimpactaccountingstandard/projects/project-alpha> ;
    nias-o:reportStatus nias-cs:verified ;
    nias-o:usesMethodology <https://nova.org.za/novaimpactaccountingstandard/methodologies/NIAS-SOLAR-001> ;
    nias-o:impactClaim <https://nova.org.za/novaimpactaccountingstandard/claims/impact-claim-alpha-monitoring-01> ;
    claimont:isSupportedBy <https://nova.org.za/novaimpactaccountingstandard/documents/source-metered-energy>,
        <https://nova.org.za/novaimpactaccountingstandard/attestations/mr-attestation-001> .

<https://nova.org.za/novaimpactaccountingstandard/claims/impact-claim-alpha-monitoring-01>
    a aiao:ImpactClaim ;
    claimont:hasSubject <https://nova.org.za/novaimpactaccountingstandard/impacts/measured-impact-alpha-2026-q1> ;
    nias-o:usesMethodology <https://nova.org.za/novaimpactaccountingstandard/methodologies/NIAS-SOLAR-001> ;
    claimont:isSupportedBy <https://nova.org.za/novaimpactaccountingstandard/documents/source-metered-energy>,
        <https://nova.org.za/novaimpactaccountingstandard/attestations/mr-attestation-001> .

<https://nova.org.za/novaimpactaccountingstandard/impacts/measured-impact-alpha-2026-q1>
    a impactont:Impact ;
    impactont:hasStateA <https://nova.org.za/novaimpactaccountingstandard/states/alpha-baseline-q1> ;
    impactont:hasStateB <https://nova.org.za/novaimpactaccountingstandard/states/alpha-project-q1> ;
    impactont:hasProvenance <https://nova.org.za/novaimpactaccountingstandard/projects/project-alpha> ;
    nias-o:monitoringPeriod <https://nova.org.za/novaimpactaccountingstandard/periods/monitoring-q1-2026> .

<https://nova.org.za/novaimpactaccountingstandard/states/alpha-baseline-q1>
    a impactont:State ;
    impactont:hasModality "real" ;
    impactont:isDefinedByIndicator <https://nova.org.za/novaimpactaccountingstandard/indicators/net-co2e-avoided> ;
    impactont:hasTemporalLocation <https://nova.org.za/novaimpactaccountingstandard/time/instant-2026-01-01> ;
    impactont:hasIndicatorValue <https://nova.org.za/novaimpactaccountingstandard/values/alpha-baseline-value-q1> .

<https://nova.org.za/novaimpactaccountingstandard/states/alpha-project-q1>
    a impactont:State ;
    impactont:hasModality "real" ;
    impactont:isDefinedByIndicator <https://nova.org.za/novaimpactaccountingstandard/indicators/net-co2e-avoided> ;
    impactont:hasTemporalLocation <https://nova.org.za/novaimpactaccountingstandard/time/instant-2026-03-31> ;
    impactont:hasIndicatorValue <https://nova.org.za/novaimpactaccountingstandard/values/alpha-project-value-q1> .

<https://nova.org.za/novaimpactaccountingstandard/values/alpha-baseline-value-q1>
    a impactont:IndicatorValue ;
    rdf:value "125.4"^^xsd:decimal .

<https://nova.org.za/novaimpactaccountingstandard/values/alpha-project-value-q1>
    a impactont:IndicatorValue ;
    rdf:value "98.1"^^xsd:decimal .

<https://nova.org.za/novaimpactaccountingstandard/periods/monitoring-q1-2026>
    a time:Interval ;
    time:hasBeginning <https://nova.org.za/novaimpactaccountingstandard/time/instant-2026-01-01> ;
    time:hasEnd <https://nova.org.za/novaimpactaccountingstandard/time/instant-2026-03-31> .

<https://nova.org.za/novaimpactaccountingstandard/time/instant-2026-01-01>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-01-01T00:00:00Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/time/instant-2026-03-31>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-03-31T23:59:59Z"^^xsd:dateTimeStamp .
