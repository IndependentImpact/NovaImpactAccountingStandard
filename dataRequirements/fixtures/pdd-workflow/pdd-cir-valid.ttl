@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix hedera: <https://hashgraphontology.xyz/core/> .
@prefix infocomm: <http://w3id.org/infocomm#> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://nova.org.za/novaimpactaccountingstandard/requests/pdd-alpha-cir>
    a data:Document,
        nias-o:PddCertificateIssuanceRequest ;
    nias-o:resourceIpfsUri "ipfs://bafypddcir"^^xsd:anyURI ;
    nias-o:documentSchema <https://nova.org.za/novaimpactaccountingstandard/document-schema/PDDCIR-3.0.0> ;
    nias-o:isEncrypted false ;
    nias-o:documentAuthor <https://nova.org.za/novaimpactaccountingstandard/users/project-developer-1> ;
    nias-o:authProof nias-cs:eddsa-signature ;
    nias-o:hasWorkflowSubmission <https://nova.org.za/novaimpactaccountingstandard/submissions/pdd-alpha-cir> ;
    nias-o:pddSectionAValidationReview [
        a nias-o:DocumentReference ;
        nias-o:documentMessageId "0.0.1001-2026-01-04T00:00:00Z" ;
        nias-o:resourceIpfsUri "ipfs://bafypddsectionareview"^^xsd:anyURI
    ] ;
    nias-o:pddSectionBValidationReview [
        a nias-o:DocumentReference ;
        nias-o:documentMessageId "0.0.1001-2026-01-05T00:00:00Z" ;
        nias-o:resourceIpfsUri "ipfs://bafypddsectionbreview"^^xsd:anyURI
    ] ;
    nias-o:pddSectionCValidationReview [
        a nias-o:DocumentReference ;
        nias-o:documentMessageId "0.0.1001-2026-01-06T00:00:00Z" ;
        nias-o:resourceIpfsUri "ipfs://bafypddsectioncreview"^^xsd:anyURI
    ] ;
    nias-o:pddSectionQualitativeReview [
        a nias-o:DocumentReference ;
        nias-o:documentMessageId "0.0.1001-2026-01-07T00:00:00Z" ;
        nias-o:resourceIpfsUri "ipfs://bafypddsectionqualreview"^^xsd:anyURI
    ] ;
    nias-o:pddDocumentLevelQualitativeReview [
        a nias-o:DocumentReference ;
        nias-o:documentMessageId "0.0.1001-2026-01-08T00:00:00Z" ;
        nias-o:resourceIpfsUri "ipfs://bafypdddocqualreview"^^xsd:anyURI
    ] ;
    nias-o:requestedIssuanceAccountId "0.0.2002" .

<https://nova.org.za/novaimpactaccountingstandard/submissions/pdd-alpha-cir>
    a nias-o:WorkflowDocumentSubmission ;
    nias-o:submittedDocument <https://nova.org.za/novaimpactaccountingstandard/requests/pdd-alpha-cir> ;
    nias-o:workflow <https://nova.org.za/novaimpactaccountingstandard/workflows/pdd> ;
    nias-o:workflowStep [
        a nias-o:WorkflowStep ;
        rdfs:label "Request PDD certificate"
    ] ;
    nias-o:workflowSubject <https://nova.org.za/novaimpactaccountingstandard/projects/pdd-alpha> ;
    nias-o:workflowDocumentSubmittedBy <https://nova.org.za/novaimpactaccountingstandard/users/project-developer-1> ;
    nias-o:workflowDocumentRecipient <https://nova.org.za/novaimpactaccountingstandard/registry/nova-registry> ;
    nias-o:workflowSubmissionConsensusMessage [
        a hedera:TopicMessage ;
        hedera:inTopic [
            a hedera:ConsensusTopic ;
            hedera:hasTopicId "0.0.1001"
        ] ;
        hedera:hasConsensusTimestamp "2026-01-07T00:00:00Z"^^xsd:dateTimeStamp
    ] .

<https://nova.org.za/novaimpactaccountingstandard/users/project-developer-1>
    a nias-o:PlatformUser .

<https://nova.org.za/novaimpactaccountingstandard/registry/nova-registry>
    a infocomm:CommunicationParty .

<https://nova.org.za/novaimpactaccountingstandard/workflows/pdd>
    a nias-o:Workflow .
