@prefix aiao: <http://w3id.org/aiao#> .
@prefix claimont: <http://w3id.org/claimont#> .
@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix hedera: <https://hashgraphontology.xyz/core/> .
@prefix impactont: <http://w3id.org/impactont#> .
@prefix infocomm: <http://w3id.org/infocomm#> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://nova.org.za/novaimpactaccountingstandard/test/pla-1>
    a data:Document,
        nias-o:ProjectListingApplication ;
    nias-o:documentSchema <https://nova.org.za/novaimpactaccountingstandard/document-schema/PLA-1.0.0> ;
    nias-o:isEncrypted false ;
    nias-o:documentAuthor <https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1> ;
    nias-o:authProof nias-o:none ;
    nias-o:resourceIpfsUri "ipfs://bafypla"^^xsd:anyURI ;
    nias-o:hasWorkflowSubmission <https://nova.org.za/novaimpactaccountingstandard/test/pla-submission-1> ;
    claimont:hasSubject <https://nova.org.za/novaimpactaccountingstandard/test/project-1> .

<https://nova.org.za/novaimpactaccountingstandard/test/project-1>
    a aiao:Project ;
    nias-o:title "Example clean cooking programme" ;
    aiao:hasObjective <https://nova.org.za/novaimpactaccountingstandard/test/project-objective-1> ;
    impactont:hasSpatialLocation <https://nova.org.za/novaimpactaccountingstandard/test/project-location-1> .

<https://nova.org.za/novaimpactaccountingstandard/test/project-objective-1>
    a aiao:Objective ;
    schema:description "Reduce household fuel consumption through efficient cookstoves." .

<https://nova.org.za/novaimpactaccountingstandard/test/project-location-1>
    a impactont:SpatialLocation ;
    schema:description "South Africa, Western Cape, Cape Town." .

<https://nova.org.za/novaimpactaccountingstandard/test/pla-submission-1>
    a nias-o:WorkflowDocumentSubmission ;
    nias-o:submittedDocument <https://nova.org.za/novaimpactaccountingstandard/test/pla-1> ;
    nias-o:workflow <https://nova.org.za/novaimpactaccountingstandard/test/project-listing-workflow> ;
    nias-o:workflowStep <https://nova.org.za/novaimpactaccountingstandard/test/submit-pla-step> ;
    nias-o:workflowSubject <https://nova.org.za/novaimpactaccountingstandard/test/project-1> ;
    nias-o:workflowDocumentSubmittedBy <https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1> ;
    nias-o:workflowDocumentRecipient <https://nova.org.za/novaimpactaccountingstandard/test/registry-1> ;
    nias-o:workflowSubmissionConsensusMessage <https://nova.org.za/novaimpactaccountingstandard/test/pla-message-1> .

<https://nova.org.za/novaimpactaccountingstandard/test/project-listing-workflow>
    a nias-o:Workflow .

<https://nova.org.za/novaimpactaccountingstandard/test/submit-pla-step>
    a nias-o:WorkflowStep ;
    rdfs:label "Submit PLA" .

<https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1>
    a nias-o:PlatformUser .

<https://nova.org.za/novaimpactaccountingstandard/test/registry-1>
    a infocomm:CommunicationParty .

<https://nova.org.za/novaimpactaccountingstandard/test/topic-1>
    a hedera:ConsensusTopic ;
    hedera:hasTopicId "0.0.1001" .

<https://nova.org.za/novaimpactaccountingstandard/test/pla-message-1>
    a hedera:TopicMessage ;
    hedera:inTopic <https://nova.org.za/novaimpactaccountingstandard/test/topic-1> ;
    hedera:hasSequenceNumber 1 ;
    hedera:hasConsensusTimestamp "2026-01-01T00:00:00Z"^^xsd:dateTimeStamp .
