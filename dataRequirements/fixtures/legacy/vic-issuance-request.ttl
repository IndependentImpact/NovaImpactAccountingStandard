@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://nova.org.za/novaimpactaccountingstandard/test/vicir-1>
    a data:Document,
        nias-o:VerifiedImpactCertificateIssuanceRequest ;
    nias-o:documentSchema <https://nova.org.za/novaimpactaccountingstandard/document-schema/VICIR-1.0.0> ;
    nias-o:isEncrypted false ;
    nias-o:documentAuthor <https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1> ;
    nias-o:authProof nias-o:none ;
    nias-o:resourceIpfsUri "ipfs://bafyvicir"^^xsd:anyURI ;
    nias-o:hasWorkflowSubmission <https://nova.org.za/novaimpactaccountingstandard/test/vicir-submission-1> ;
    nias-o:monitoringReportReview <https://nova.org.za/novaimpactaccountingstandard/test/dr-mr-reference-1> ;
    nias-o:impactSummary <https://nova.org.za/novaimpactaccountingstandard/test/vicir-impact-summary-1> ;
    nias-o:requestedIssuanceAccountId "0.0.3003" .

<https://nova.org.za/novaimpactaccountingstandard/test/dr-mr-reference-1>
    a nias-o:DocumentReference ;
    nias-o:documentMessageId "0.0.1001-1704067200-000000007" ;
    nias-o:resourceIpfsUri "ipfs://bafydrmr"^^xsd:anyURI .

<https://nova.org.za/novaimpactaccountingstandard/test/vicir-impact-summary-1>
    a nias-o:ImpactSummary ;
    nias-o:impactDescription "Measured impact verified for the Q1 2026 monitoring period." ;
    ind:timePeriod <https://nova.org.za/novaimpactaccountingstandard/test/vicir-period-1> ;
    ind:hasUnit qudt-unit:TONNE ;
    ind:obsValue 123.45 .

<https://nova.org.za/novaimpactaccountingstandard/test/vicir-period-1>
    a time:Interval ;
    time:hasBeginning <https://nova.org.za/novaimpactaccountingstandard/test/vicir-period-start-1> ;
    time:hasEnd <https://nova.org.za/novaimpactaccountingstandard/test/vicir-period-end-1> .

<https://nova.org.za/novaimpactaccountingstandard/test/vicir-period-start-1>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-01-01T00:00:00Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/test/vicir-period-end-1>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-03-31T23:59:59Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/test/vicir-submission-1>
    a nias-o:WorkflowDocumentSubmission ;
    nias-o:submittedDocument <https://nova.org.za/novaimpactaccountingstandard/test/vicir-1> ;
    nias-o:workflow <https://nova.org.za/novaimpactaccountingstandard/test/certificate-workflow> ;
    nias-o:workflowStep <https://nova.org.za/novaimpactaccountingstandard/test/request-vic-step> ;
    nias-o:workflowSubject <https://nova.org.za/novaimpactaccountingstandard/test/project-1> ;
    nias-o:workflowDocumentSubmittedBy <https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1> ;
    nias-o:workflowDocumentRecipient <https://nova.org.za/novaimpactaccountingstandard/test/registry-1> ;
    nias-o:workflowSubmissionConsensusMessage <https://nova.org.za/novaimpactaccountingstandard/test/vicir-message-1> .

<https://nova.org.za/novaimpactaccountingstandard/test/certificate-workflow>
    a nias-o:Workflow .

<https://nova.org.za/novaimpactaccountingstandard/test/request-vic-step>
    a nias-o:WorkflowStep ;
    rdfs:label "Request verified impact certificate" .

<https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1>
    a nias-o:PlatformUser .

<https://nova.org.za/novaimpactaccountingstandard/test/registry-1>
