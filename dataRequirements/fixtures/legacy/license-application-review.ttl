@prefix aiao: <http://w3id.org/aiao#> .
@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix hedera: <https://hashgraphontology.xyz/core/> .
@prefix infocomm: <http://w3id.org/infocomm#> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# License application review (DR-LicenseApplication) –
# typed as data:Document, nias-o:LicenseApplicationReview, and nias-o:DocumentReview.

<https://nova.org.za/novaimpactaccountingstandard/license-application-reviews/lar-001>
    a data:Document, nias-o:LicenseApplicationReview, nias-o:DocumentReview ;
    nias-o:finalReviewDecision nias-cs:review-approve ;
    nias-o:reviewerCommentary "Agent details verified; license scope confirmed. Application approved." ;
    nias-o:licenseScope nias-cs:project-developer ;
    nias-o:requestedIssuanceAccountId "0.0.12345" ;
    nias-o:agentDetailsReview [
        a nias-o:DocumentReference ;
        nias-o:documentMessageId "0.0.9000@12345" ;
        nias-o:resourceIpfsUri "ipfs://QmAgentDetailsReviewHash001"^^xsd:anyURI
    ] ;
    nias-o:resourceIpfsUri "ipfs://QmLicenseApplicationReviewHash001"^^xsd:anyURI ;
    nias-o:documentSchema <https://nova.org.za/novaimpactaccountingstandard/document-schema/DR-LicenseApplication-1.0.0> ;
    nias-o:isEncrypted false ;
    nias-o:documentAuthor <https://nova.org.za/novaimpactaccountingstandard/agents/reviewer-001> ;
    nias-o:authProof nias-cs:eddsa-signature ;
    nias-o:hasWorkflowSubmission <https://nova.org.za/novaimpactaccountingstandard/submissions/lar-sub-001> .

<https://nova.org.za/novaimpactaccountingstandard/submissions/lar-sub-001>
    a nias-o:WorkflowDocumentSubmission ;
    nias-o:submittedDocument <https://nova.org.za/novaimpactaccountingstandard/license-application-reviews/lar-001> ;
    nias-o:workflow <https://nova.org.za/novaimpactaccountingstandard/workflows/agent-license-workflow> ;
    nias-o:workflowStep [
        a nias-o:WorkflowStep ;
        rdfs:label "Review license application"
    ] ;
    nias-o:workflowSubject <https://nova.org.za/novaimpactaccountingstandard/agents/agent-lic-001> ;
    nias-o:workflowDocumentSubmittedBy <https://nova.org.za/novaimpactaccountingstandard/agents/reviewer-001> ;
    nias-o:workflowDocumentRecipient <https://nova.org.za/novaimpactaccountingstandard/platform/nova> ;
    nias-o:workflowSubmissionConsensusMessage [
        a hedera:TopicMessage ;
        hedera:inTopic [
            a hedera:ConsensusTopic ;
            hedera:hasTopicId "0.0.9000"
        ] ;
        hedera:hasConsensusTimestamp "2026-01-20T14:00:00Z"^^xsd:dateTimeStamp
    ] .

<https://nova.org.za/novaimpactaccountingstandard/agents/agent-lic-001>
    a aiao:Agent, nias-o:PlatformUser .

<https://nova.org.za/novaimpactaccountingstandard/agents/reviewer-001>
    a aiao:Agent, nias-o:PlatformUser .

<https://nova.org.za/novaimpactaccountingstandard/platform/nova>
    a infocomm:CommunicationParty .

<https://nova.org.za/novaimpactaccountingstandard/workflows/agent-license-workflow>
    a nias-o:Workflow .
