@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix time: <http://www.w3.org/2006/time#> .

[
  a nias-o:CreditingPeriod ;
  time:hasBeginning [
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-01-01T00:00:00Z"
  ] ;
  time:hasEnd [
    a time:Instant ;
    time:inXSDDateTimeStamp "2030-12-31T23:59:59Z"
  ] ;
  nias-o:creditingPeriodIsRenewable true
] .
