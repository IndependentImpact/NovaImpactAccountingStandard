<https://nova.org.za/novaimpactaccountingstandard/test/pdd-xc-1>
    a data:Document,
        nias-o:PddSectionCStakeholderEngagement ;
    nias-o:documentSchema <https://nova.org.za/novaimpactaccountingstandard/document-schema/PDDxC-4.0.0> ;
    nias-o:isEncrypted false ;
    nias-o:documentAuthor <https://nova.org.za/novaimpactaccountingstandard/test/project-developer-1> ;
    nias-o:authProof nias-o:none ;
    nias-o:resourceIpfsUri "ipfs://bafypddxc"^^xsd:anyURI ;
    nias-o:hasWorkflowSubmission <https://nova.org.za/novaimpactaccountingstandard/test/pdd-xc-submission-1> ;
    nias-o:stakeholderEngagementModalities "In-person meetings and public notice periods in affected communities." ;
    nias-o:stakeholderCommentSummary "Stakeholders asked for clear maintenance responsibilities and local training." ;
    nias-o:stakeholderCommentConsideration "The project design includes a local maintenance and training plan." .

<https://nova.org.za/novaimpactaccountingstandard/test/pdd-xc-submission-1>
    a nias-o:WorkflowDocumentSubmission ;
    nias-o:submittedDocument <https://nova.org.za/novaimpactaccountingstandard/test/pdd-xc-1> ;
