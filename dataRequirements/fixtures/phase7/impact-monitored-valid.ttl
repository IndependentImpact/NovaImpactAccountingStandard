@prefix impactont: <http://w3id.org/impactont#> .
@prefix ind: <http://independentimpact.org/indicator-owl/> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://nova.org.za/novaimpactaccountingstandard/impacts/phase7-monitored>
    a impactont:Impact ;
    nias-o:impactIntentionality nias-cs:intentional ;
    nias-o:beneficialOrAdverse nias-cs:beneficial ;
    schema:description "Measured reduction in electricity-grid emissions." ;
    nias-o:monitored nias-cs:yes ;
    nias-o:additionalityJustification "Without project intervention this reduction would not occur." ;
    impactont:hasStateA <https://nova.org.za/novaimpactaccountingstandard/states/phase7-monitored-a> ;
    impactont:hasStateB <https://nova.org.za/novaimpactaccountingstandard/states/phase7-monitored-b> ;
    impactont:hasProvenance <https://nova.org.za/novaimpactaccountingstandard/projects/phase7-project> ;
    nias-o:creditingPeriod <https://nova.org.za/novaimpactaccountingstandard/periods/phase7-crediting> ;
    nias-o:monitoringPeriod <https://nova.org.za/novaimpactaccountingstandard/periods/phase7-monitoring> ;
    nias-o:dataParameterRequirement <https://nova.org.za/novaimpactaccountingstandard/data-parameters/phase7-parameter> ;
    nias-o:exAnteImpactEstimate "80.5"^^xsd:decimal .

<https://nova.org.za/novaimpactaccountingstandard/states/phase7-monitored-a>
    a impactont:State ;
    impactont:hasTemporalLocation <https://nova.org.za/novaimpactaccountingstandard/time/phase7-crediting-start> ;
    impactont:hasModality "counterfactual" ;
    impactont:isDefinedByIndicator <https://nova.org.za/novaimpactaccountingstandard/indicators/phase7-indicator> ;
    impactont:hasIndicatorValue <https://nova.org.za/novaimpactaccountingstandard/values/phase7-value-a> .

<https://nova.org.za/novaimpactaccountingstandard/states/phase7-monitored-b>
    a impactont:State ;
    impactont:hasTemporalLocation <https://nova.org.za/novaimpactaccountingstandard/time/phase7-monitoring-end> ;
    impactont:hasModality "real" ;
    impactont:isDefinedByIndicator <https://nova.org.za/novaimpactaccountingstandard/indicators/phase7-indicator> ;
    impactont:hasIndicatorValue <https://nova.org.za/novaimpactaccountingstandard/values/phase7-value-b> .

<https://nova.org.za/novaimpactaccountingstandard/values/phase7-value-a>
    a impactont:IndicatorValue ;
    rdf:value "100.0"^^xsd:decimal .

<https://nova.org.za/novaimpactaccountingstandard/values/phase7-value-b>
    a impactont:IndicatorValue ;
    rdf:value "55.0"^^xsd:decimal .

<https://nova.org.za/novaimpactaccountingstandard/periods/phase7-crediting>
    a nias-o:CreditingPeriod ;
    time:hasBeginning <https://nova.org.za/novaimpactaccountingstandard/time/phase7-crediting-start> ;
    time:hasEnd <https://nova.org.za/novaimpactaccountingstandard/time/phase7-crediting-end> ;
    nias-o:creditingPeriodIsRenewable false .

<https://nova.org.za/novaimpactaccountingstandard/periods/phase7-monitoring>
    a time:Interval ;
    time:hasBeginning <https://nova.org.za/novaimpactaccountingstandard/time/phase7-monitoring-start> ;
    time:hasEnd <https://nova.org.za/novaimpactaccountingstandard/time/phase7-monitoring-end> .

<https://nova.org.za/novaimpactaccountingstandard/time/phase7-crediting-start>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-01-01T00:00:00Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/time/phase7-crediting-end>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-12-31T23:59:59Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/time/phase7-monitoring-start>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-02-01T00:00:00Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/time/phase7-monitoring-end>
    a time:Instant ;
    time:inXSDDateTimeStamp "2026-11-30T23:59:59Z"^^xsd:dateTimeStamp .

<https://nova.org.za/novaimpactaccountingstandard/data-parameters/phase7-parameter>
    a nias-o:DataParameterRequirement ;
    rdfs:label "Metered electricity output" ;
    schema:description "Measured electricity output for the crediting year." ;
    nias-o:dataParameterPurpose "Compute annual net avoided emissions." ;
    ind:hasUnit <http://qudt.org/vocab/unit/KiloW-HR> ;
    nias-o:monitoredOrFixed nias-cs:monitored ;
    nias-o:measurementMethodsAndProcedures "Daily meter reading at export point." ;
    nias-o:qaQcProcedures "Monthly cross-check against utility statement." ;
    nias-o:monitoringFrequency "daily" ;
    nias-o:samplingPlan "100% data capture from certified meter." .
