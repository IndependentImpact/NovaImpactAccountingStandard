# REQ-PDD-001 negative fixture
# A PddSectionAReport that violates ReqPdd001Shape:
#   - MISSING claimont:isMadeBy (no developer agent declared)
#   - the project subject has a title and a project activity (only agent is absent)

@prefix aiao: <http://w3id.org/aiao#> .
@prefix claimont: <http://w3id.org/claimont#> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .

<https://nova.org.za/novaimpactaccountingstandard/vvs/fixtures/pdd-a-invalid-project>
    a aiao:Project ;
    nias-o:title "VVS Test Solar Project (invalid)" ;
    nias-o:technologyOrMeasure [
        a nias-o:TechnologyOrMeasure ;
        nias-o:techMeasType nias-cs:facility
    ] .

<https://nova.org.za/novaimpactaccountingstandard/vvs/fixtures/pdd-a-invalid-report>
    a nias-o:PddSectionAReport ;
    claimont:hasSubject <https://nova.org.za/novaimpactaccountingstandard/vvs/fixtures/pdd-a-invalid-project> .
    # claimont:isMadeBy intentionally omitted to trigger REQ-PDD-001 violation
