@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ind: <http://independentimpact.org/indicator-owl/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nias-o:MonitoringReportShapes a owl:Ontology ;
    dcterms:title "Nova Impact Accounting Standard - Monitoring Report SHACL Shapes"@en ;
    dcterms:description "Monitoring report and dataset shapes for the legacy MR workflow document."@en ;
    owl:imports nias-o:DocumentReferenceShapes,
        nias-o:DocumentShapes .

nias-o:DatasetShape a sh:NodeShape ;
    sh:targetClass nias-o:Dataset ;
    sh:property [
        sh:path dcterms:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report dataset must have exactly one dataset name."@en
    ] ;
    sh:property [
        sh:path nias-o:dataLineageReview ;
        sh:class nias-o:DocumentReference ;
        sh:node nias-o:DocumentReferenceShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report dataset must reference the approved data lineage review."@en
    ] ;
    sh:property [
        sh:path nias-o:finalDatasetArtifact ;
        sh:class nias-o:ResourceArtifact ;
        sh:node nias-o:ResourceArtifactShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report dataset must reference the final approved dataset artifact."@en
    ] .

nias-o:MonitoringReportShape a sh:NodeShape ;
    sh:targetClass nias-o:MonitoringReport ;
    sh:property [
        sh:path nias-o:hasWorkflowSubmission ;
        sh:class nias-o:WorkflowDocumentSubmission ;
        sh:node nias-o:WorkflowDocumentSubmissionShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must include its workflow submission headers."@en
    ] ;
    sh:property [
        sh:path nias-o:reportedIndicatorLabel ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must preserve the legacy indicator label."@en
    ] ;
    sh:property [
        sh:path nias-o:forPeriod ;
        sh:class time:Interval ;
        sh:node nias-o:DateTimeIntervalShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must identify exactly one monitoring period."@en
    ] ;
    sh:property [
        sh:path nias-o:reportedObservation ;
        sh:class ind:IndicatorObservation ;
        sh:node nias-o:IndicatorObservationShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must include exactly one measured impact observation."@en
    ] ;
    sh:property [
        sh:path nias-o:usesDataset ;
        sh:class nias-o:Dataset ;
        sh:node nias-o:DatasetShape ;
        sh:minCount 1 ;
        sh:message "A monitoring report must reference at least one dataset used in the calculation."@en
    ] ;
    sh:property [
        sh:path nias-o:calculationCode ;
        sh:class nias-o:ResourceArtifact ;
        sh:node nias-o:ResourceArtifactShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must reference the RMD or code that performed the calculation."@en
    ] ;
    sh:property [
        sh:path nias-o:impactResultResource ;
        sh:class nias-o:ResourceArtifact ;
        sh:node nias-o:ResourceArtifactShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must reference the impact calculation result resource."@en
    ] ;
    sh:property [
        sh:path nias-o:calculationReport ;
        sh:class nias-o:ResourceArtifact ;
        sh:node nias-o:ResourceArtifactShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must reference the calculation report resource."@en
    ] ;
    sh:property [
        sh:path nias-o:requestedIssuanceAccountId ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d+\\.\\d+\\.\\d+$" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A monitoring report must include the Hedera account ID for issuance."@en
    ] .
