@prefix aiao: <http://w3id.org/aiao#> .
@prefix claimont: <http://w3id.org/claimont#> .
@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hedera: <https://hashgraphontology.xyz/core/> .
@prefix impactont: <http://w3id.org/impactont#> .
@prefix ind: <http://independentimpact.org/indicator-owl/> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-ui: <https://nova.org.za/novaimpactaccountingstandard/shape2flutter/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix ui: <https://shape2flutter.dev/vocab/ui#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nias-ui:PddWorkflowUiShapes a owl:Ontology ;
    dcterms:title "NIAS PDD workflow shape2flutter UI shapes"@en ;
    dcterms:description "Flattened UI-facing SHACL views for PDD creation and validation forms. Canonical validation constraints remain in dataRequirements/*.ttl."@en .

nias-ui:TimeInstantUiShape a sh:NodeShape ;
    sh:targetClass time:Instant ;
    sh:property [
        sh:path time:inXSDDateTimeStamp ;
        sh:datatype xsd:dateTimeStamp ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Date and time" ;
        ui:widget ui:dateTime ;
        ui:order 1 ;
    ] .

nias-ui:DateTimeIntervalUiShape a sh:NodeShape ;
    sh:targetClass time:Interval ;
    sh:property [
        sh:path time:hasBeginning ;
        sh:node nias-ui:TimeInstantUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Start" ;
        ui:widget ui:subform ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path time:hasEnd ;
        sh:node nias-ui:TimeInstantUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "End" ;
        ui:widget ui:subform ;
        ui:order 2 ;
    ] .

nias-ui:CreditingPeriodUiShape a sh:NodeShape ;
    sh:targetClass nias-o:CreditingPeriod ;
    sh:property [
        sh:path time:hasBeginning ;
        sh:node nias-ui:TimeInstantUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Crediting period start" ;
        ui:widget ui:subform ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path time:hasEnd ;
        sh:node nias-ui:TimeInstantUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Crediting period end" ;
        ui:widget ui:subform ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path nias-o:creditingPeriodIsRenewable ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Renewable crediting period" ;
        ui:widget ui:switch ;
        ui:order 3 ;
    ] .

nias-ui:HederaTopicMessageUiShape a sh:NodeShape ;
    sh:targetClass hedera:TopicMessage ;
    sh:property [
        sh:path hedera:inTopic ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Consensus topic" ;
        ui:help "IRI for the Hedera consensus topic." ;
        ui:widget ui:text ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path hedera:hasSequenceNumber ;
        sh:datatype xsd:integer ;
        sh:maxCount 1 ;
        ui:label "Sequence number" ;
        ui:widget ui:number ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path hedera:hasConsensusTimestamp ;
        sh:datatype xsd:dateTimeStamp ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Consensus timestamp" ;
        ui:widget ui:dateTime ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path hedera:hasMessageContent ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Message content" ;
        ui:widget ui:textarea ;
        ui:order 4 ;
    ] .

nias-ui:WorkflowDocumentSubmissionUiShape a sh:NodeShape ;
    sh:targetClass nias-o:WorkflowDocumentSubmission ;
    sh:property [
        sh:path nias-o:submittedDocument ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Submitted document" ;
        ui:widget ui:text ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path nias-o:workflow ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Workflow" ;
        ui:widget ui:text ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path nias-o:workflowStep ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Workflow step" ;
        ui:widget ui:text ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path nias-o:workflowSubject ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Workflow subject" ;
        ui:widget ui:text ;
        ui:order 4 ;
    ] ;
    sh:property [
        sh:path nias-o:workflowDocumentSubmittedBy ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Submitted by" ;
        ui:widget ui:text ;
        ui:order 5 ;
    ] ;
    sh:property [
        sh:path nias-o:workflowDocumentRecipient ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Recipient" ;
        ui:widget ui:text ;
        ui:order 6 ;
    ] ;
    sh:property [
        sh:path nias-o:workflowSubmissionConsensusMessage ;
        sh:node nias-ui:HederaTopicMessageUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Consensus message" ;
        ui:widget ui:subform ;
        ui:order 7 ;
    ] .

nias-ui:DocumentReferenceUiShape a sh:NodeShape ;
    sh:targetClass nias-o:DocumentReference ;
    sh:property [
        sh:path nias-o:documentMessageId ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Message ID" ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path nias-o:resourceIpfsUri ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "IPFS URI" ;
        ui:widget ui:ipfs ;
        ui:order 2 ;
    ] .

nias-ui:ObjectiveUiShape a sh:NodeShape ;
    sh:targetClass aiao:Objective ;
    sh:property [
        sh:path schema:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Objective" ;
        ui:widget ui:textarea ;
        ui:order 1 ;
    ] .

nias-ui:SpatialLocationUiShape a sh:NodeShape ;
    sh:targetClass impactont:SpatialLocation ;
    sh:property [
        sh:path nias-o:resourceIpfsUri ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Location IPFS URI" ;
        ui:widget ui:ipfs ;
        ui:order 1 ;
    ] .

nias-ui:TechnologyOrMeasureUiShape a sh:NodeShape ;
    sh:targetClass nias-o:TechnologyOrMeasure ;
    sh:property [
        sh:path nias-o:techMeasType ;
        sh:in ( nias-cs:facility nias-cs:system nias-cs:equipment nias-cs:other ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Type" ;
        ui:widget ui:select ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path schema:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Description" ;
        ui:widget ui:textarea ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path nias-o:currentAgeInYears ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0 ;
        ui:label "Current age in years" ;
        ui:widget ui:number ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path nias-o:estimatedLifespanInYears ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0 ;
        ui:label "Estimated lifespan in years" ;
        ui:widget ui:number ;
        ui:order 4 ;
    ] ;
    sh:property [
        sh:path nias-o:additionalInfo ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Additional information" ;
        ui:widget ui:textarea ;
        ui:order 5 ;
    ] .

nias-ui:ProjectPartyUiShape a sh:NodeShape ;
    sh:targetClass nias-o:ProjectParty ;
    sh:property [
        sh:path nias-o:partyName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Party name" ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path nias-o:isHostParty ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Host party" ;
        ui:widget ui:switch ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path nias-o:isParticipantParty ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Participant party" ;
        ui:widget ui:switch ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path nias-o:publicPrivateClassification ;
        sh:in ( nias-cs:public nias-cs:private ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Public or private" ;
        ui:widget ui:radio ;
        ui:order 4 ;
    ] ;
    sh:property [
        sh:path nias-o:additionalInfo ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Additional information" ;
        ui:widget ui:textarea ;
        ui:order 5 ;
    ] .

nias-ui:ProjectDesignUiShape a sh:NodeShape ;
    sh:targetClass aiao:Project ;
    sh:property [
        sh:path nias-o:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Project title" ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path aiao:hasObjective ;
        sh:node nias-ui:ObjectiveUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Project purpose" ;
        ui:widget ui:subform ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path impactont:hasSpatialLocation ;
        sh:node nias-ui:SpatialLocationUiShape ;
        sh:minCount 1 ;
        sh:maxCount 99 ;
        ui:label "Project locations" ;
        ui:widget ui:subform ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path nias-o:technologyOrMeasure ;
        sh:node nias-ui:TechnologyOrMeasureUiShape ;
        sh:minCount 1 ;
        sh:maxCount 99 ;
        ui:label "Technologies and measures" ;
        ui:widget ui:subform ;
        ui:order 4 ;
    ] ;
    sh:property [
        sh:path nias-o:projectParty ;
        sh:node nias-ui:ProjectPartyUiShape ;
        sh:minCount 1 ;
        sh:maxCount 99 ;
        ui:label "Project parties" ;
        ui:widget ui:subform ;
        ui:order 5 ;
    ] ;
    sh:property [
        sh:path nias-o:legalMatters ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Legal matters" ;
        ui:widget ui:textarea ;
        ui:order 6 ;
    ] ;
    sh:property [
        sh:path nias-o:publicFundingStatus ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Public funding" ;
        ui:widget ui:switch ;
        ui:order 7 ;
    ] ;
    sh:property [
        sh:path nias-o:publicFundingSource ;
        sh:datatype xsd:string ;
        sh:maxCount 99 ;
        ui:label "Public funding sources" ;
        ui:widget ui:chips ;
        ui:order 8 ;
    ] ;
    sh:property [
        sh:path nias-o:projectHistory ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Project history" ;
        ui:widget ui:textarea ;
        ui:order 9 ;
    ] ;
    sh:property [
        sh:path nias-o:debundlingAssessment ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Debundling assessment" ;
        ui:widget ui:textarea ;
        ui:order 10 ;
    ] ;
    sh:property [
        sh:path nias-o:eligibilityDescription ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Eligibility description" ;
        ui:widget ui:textarea ;
        ui:order 11 ;
    ] .

nias-ui:DataParameterRequirementUiShape a sh:NodeShape ;
    sh:targetClass nias-o:DataParameterRequirement ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Parameter label" ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path schema:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Description" ;
        ui:widget ui:textarea ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path nias-o:dataParameterPurpose ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Purpose" ;
        ui:widget ui:textarea ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path ind:hasUnit ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Unit IRI" ;
        ui:help "Use a QUDT unit IRI." ;
        ui:order 4 ;
    ] ;
    sh:property [
        sh:path nias-o:monitoredOrFixed ;
        sh:in ( nias-cs:monitored nias-cs:fixed-ex-ante ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Monitoring status" ;
        ui:widget ui:radio ;
        ui:order 5 ;
    ] ;
    sh:property [
        sh:path nias-o:measurementMethodsAndProcedures ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Measurement methods and procedures" ;
        ui:widget ui:textarea ;
        ui:order 6 ;
    ] ;
    sh:property [
        sh:path nias-o:qaQcProcedures ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "QA/QC procedures" ;
        ui:widget ui:textarea ;
        ui:order 7 ;
    ] ;
    sh:property [
        sh:path nias-o:monitoringFrequency ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Monitoring frequency" ;
        ui:order 8 ;
    ] ;
    sh:property [
        sh:path nias-o:samplingPlan ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Sampling plan" ;
        ui:widget ui:textarea ;
        ui:order 9 ;
    ] ;
    sh:property [
        sh:path nias-o:parameterAppliedValue ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        ui:label "Applied value" ;
        ui:widget ui:number ;
        ui:order 10 ;
    ] ;
    sh:property [
        sh:path nias-o:dataSource ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Data source" ;
        ui:widget ui:textarea ;
        ui:order 11 ;
    ] .

nias-ui:IndicatorValueUiShape a sh:NodeShape ;
    sh:targetClass impactont:IndicatorValue ;
    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Indicator value" ;
        ui:widget ui:number ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path ind:hasUnit ;
        sh:datatype xsd:anyURI ;
        sh:maxCount 1 ;
        ui:label "Unit IRI" ;
        ui:help "Use a QUDT unit IRI if the value carries its own unit." ;
        ui:order 2 ;
    ] .

nias-ui:StateWithIndicatorValueUiShape a sh:NodeShape ;
    sh:targetClass impactont:State ;
    sh:property [
        sh:path impactont:hasTemporalLocation ;
        sh:node nias-ui:TimeInstantUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Temporal location" ;
        ui:widget ui:subform ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path impactont:hasModality ;
        sh:in ( "counterfactual" "real" ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "State modality" ;
        ui:widget ui:radio ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path impactont:isDefinedByIndicator ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Indicator definition IRI" ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path impactont:hasIndicatorValue ;
        sh:node nias-ui:IndicatorValueUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Indicator value" ;
        ui:widget ui:subform ;
        ui:order 4 ;
    ] .

nias-ui:ImpactRequirementUiShape a sh:NodeShape ;
    sh:targetClass impactont:Impact ;
    sh:property [
        sh:path nias-o:impactIntentionality ;
        sh:in ( nias-cs:intentional nias-cs:unintentional ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Intentionality" ;
        ui:widget ui:radio ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path nias-o:beneficialOrAdverse ;
        sh:in ( nias-cs:beneficial nias-cs:adverse ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Beneficial or adverse" ;
        ui:widget ui:radio ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path schema:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Impact description" ;
        ui:widget ui:textarea ;
        ui:order 3 ;
    ] ;
    sh:property [
        sh:path nias-o:monitored ;
        sh:datatype xsd:boolean ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Monitored" ;
        ui:widget ui:switch ;
        ui:order 4 ;
    ] ;
    sh:property [
        sh:path nias-o:notMonitoredJustification ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Not monitored justification" ;
        ui:widget ui:textarea ;
        ui:order 5 ;
    ] ;
    sh:property [
        sh:path nias-o:additionalityJustification ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        ui:label "Additionality justification" ;
        ui:widget ui:textarea ;
        ui:order 6 ;
    ] ;
    sh:property [
        sh:path impactont:hasStateA ;
        sh:node nias-ui:StateWithIndicatorValueUiShape ;
        sh:maxCount 1 ;
        ui:label "Baseline or counterfactual state" ;
        ui:widget ui:subform ;
        ui:order 7 ;
    ] ;
    sh:property [
        sh:path impactont:hasStateB ;
        sh:node nias-ui:StateWithIndicatorValueUiShape ;
        sh:maxCount 1 ;
        ui:label "Project or real state" ;
        ui:widget ui:subform ;
        ui:order 8 ;
    ] ;
    sh:property [
        sh:path impactont:hasProvenance ;
        sh:datatype xsd:anyURI ;
        sh:maxCount 99 ;
        ui:label "Provenance resources" ;
        ui:widget ui:chips ;
        ui:order 9 ;
    ] ;
    sh:property [
        sh:path nias-o:creditingPeriod ;
        sh:node nias-ui:CreditingPeriodUiShape ;
        sh:maxCount 1 ;
        ui:label "Crediting period" ;
        ui:widget ui:subform ;
        ui:order 10 ;
    ] ;
    sh:property [
        sh:path nias-o:monitoringPeriod ;
        sh:node nias-ui:DateTimeIntervalUiShape ;
        sh:maxCount 99 ;
        ui:label "Monitoring periods" ;
        ui:widget ui:subform ;
        ui:order 11 ;
    ] ;
    sh:property [
        sh:path nias-o:dataParameterRequirement ;
        sh:node nias-ui:DataParameterRequirementUiShape ;
        sh:maxCount 99 ;
        ui:label "Data and parameter requirements" ;
        ui:widget ui:subform ;
        ui:order 12 ;
    ] ;
    sh:property [
        sh:path nias-o:exAnteImpactEstimate ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        ui:label "Ex-ante impact estimate" ;
        ui:widget ui:number ;
        ui:order 13 ;
    ] .

nias-ui:ImpactClaimUiShape a sh:NodeShape ;
    sh:targetClass aiao:ImpactClaim ;
    sh:property [
        sh:path claimont:hasSubject ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Project subject IRI" ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path nias-o:usesMethodology ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 99 ;
        ui:label "Methodology IRIs" ;
        ui:widget ui:chips ;
        ui:order 2 ;
    ] .

nias-ui:PddSectionAReportContentUiShape a sh:NodeShape ;
    sh:targetClass nias-o:PddSectionAReport ;
    sh:property [
        sh:path claimont:isMadeBy ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Reporting agent IRI" ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path claimont:hasSubject ;
        sh:node nias-ui:ProjectDesignUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "Project design" ;
        ui:widget ui:subform ;
        ui:order 2 ;
    ] .

nias-ui:PddSectionBReportContentUiShape a sh:NodeShape ;
    sh:targetClass nias-o:PddSectionBReport ;
    sh:property [
        sh:path nias-o:hasDeclaredImpact ;
        sh:node nias-ui:ImpactRequirementUiShape ;
        sh:minCount 1 ;
        sh:maxCount 99 ;
        ui:label "Declared impacts" ;
        ui:widget ui:subform ;
        ui:order 1 ;
    ] ;
    sh:property [
        sh:path nias-o:impactClaim ;
        sh:node nias-ui:ImpactClaimUiShape ;
        sh:minCount 1 ;
        sh:maxCount 99 ;
        ui:label "Impact claims" ;
        ui:widget ui:subform ;
        ui:order 2 ;
    ] ;
    sh:property [
        sh:path nias-o:usesMethodology ;
        sh:datatype xsd:anyURI ;
        sh:maxCount 99 ;
        ui:label "Report methodology IRIs" ;
        ui:widget ui:chips ;
        ui:order 3 ;
    ] .

nias-ui:PddSectionAUiShape a sh:NodeShape ;
    sh:targetClass data:Document ;
    sh:property [
        sh:path nias-o:reportContent ;
        sh:node nias-ui:PddSectionAReportContentUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        ui:label "PDD Section A content" ;
        ui:widget ui:subform ;
        ui:order 1 ;
    ] .

nias-ui:PddSectionBUiShape a sh:NodeShape ;
    sh:targetClass data:Document ;
    sh:property [
        sh:path nias-o:reportContent ;
        sh:node nias-ui:PddSectionBReportContentUiShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
