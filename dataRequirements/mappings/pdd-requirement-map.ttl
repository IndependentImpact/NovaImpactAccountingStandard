<https://nova.org.za/novaimpactaccountingstandard/mappings/pdd-requirement-map/> a owl:Ontology ;
    dcterms:title "NIAS VVS Phase 3 PDD requirement mapping"@en ;
    dcterms:description "Phase 3 mapping triples linking pilot VVS requirements to deterministic PDD validation anchors."@en .

nias-vvs:REQ-PDD-001 nias-o:implementedByShape nias-o:ReqPdd001Shape ;
    nias-o:validatedAt nias-o:PddSectionAReport .

nias-vvs:REQ-PDD-002 nias-o:implementedByShape nias-o:ReqPdd002Shape ;
    nias-o:validatedAt nias-o:PddSectionBReport .

nias-vvs:REQ-DLR-001 nias-o:implementedByShape nias-o:ReqDlr001Shape ;
    nias-o:validatedAt nias-o:PddSectionBReport .

nias-vvs:REQ-MR-001 nias-o:implementedByShape nias-o:ReqMr001Shape ;
    nias-o:validatedAt nias-o:PddSectionBReport .

nias-vvs:REQ-CROSS-001 nias-o:implementedByShape nias-o:ReqCross001Shape ;
    nias-o:validatedAt nias-o:PddSectionBReport .
