@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nias-o:StakeholderEngagementShapes a owl:Ontology ;
    dcterms:title "Nova Impact Accounting Standard - Stakeholder Engagement SHACL Shapes"@en ;
    dcterms:description "PDD section C stakeholder engagement shapes for the legacy PDD-XC workflow document."@en ;
    owl:imports nias-o:DocumentShapes .

nias-o:PddSectionCShape a sh:NodeShape ;
    sh:targetClass nias-o:PddSectionCStakeholderEngagement ;
    sh:property [
        sh:path nias-o:hasWorkflowSubmission ;
        sh:class nias-o:WorkflowDocumentSubmission ;
        sh:node nias-o:WorkflowDocumentSubmissionShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A PDD-C document must include its workflow submission headers."@en
    ] ;
    sh:property [
        sh:path nias-o:stakeholderEngagementModalities ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A PDD-C document must describe the local stakeholder consultation modalities."@en
    ] ;
    sh:property [
        sh:path nias-o:stakeholderCommentSummary ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "A PDD-C document may include one summary of stakeholder comments received."@en
    ] ;
    sh:property [
        sh:path nias-o:stakeholderCommentConsideration ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "A PDD-C document may include one description of how stakeholder comments were considered."@en
    ] .
