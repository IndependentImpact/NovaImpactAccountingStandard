ghg-m:ams-iiie a meth:Methodology, skos:Concept ;
    skos:prefLabel "AMS-III.E — Avoidance of methane production from decay of biomass through controlled combustion, gasification or mechanical/thermal treatment"@en ;
    meth:methodCode "AMS-III.E" ;
