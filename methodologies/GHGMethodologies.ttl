# ===========================================================================
# SMALL-SCALE METHODOLOGIES — TYPE III (Methane, waste, and other activities)
# ===========================================================================

ghg-m:ams-iiia a meth:Methodology, skos:Concept ;
    skos:prefLabel "AMS-III.A — Offsetting of synthetic nitrogen fertilizers by inoculant application"@en ;
    meth:methodCode "AMS-III.A" ;
    dct:description "Small-scale methodology for GHG emission reductions from the application of nitrogen-fixing bacterial inoculants to legume crops, reducing the need for synthetic nitrogen fertilizers and associated N₂O emissions."@en ;
    nias-o:approvalStatus nias-cs:approved ;
    meth:forIndicator nias-ind:ghg-tco2e-per-year ;
