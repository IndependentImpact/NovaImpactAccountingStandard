@prefix indimp: <https://independentimpact.org/ns/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

indimp:adverse a skos:Concept ;
    skos:definition "Impact that has an adverse environmental effect." ;
    skos:inScheme indimp:BeneficialOrAdverse ;
    skos:prefLabel "Adverse" ;
    skos:topConceptOf indimp:BeneficialOrAdverse .

indimp:beneficial a skos:Concept ;
    skos:definition "Impact that has a beneficial environmental effect." ;
    skos:inScheme indimp:BeneficialOrAdverse ;
    skos:prefLabel "Beneficial" ;
    skos:topConceptOf indimp:BeneficialOrAdverse .

indimp:eddsa-signature a skos:Concept ;
    skos:definition "Authenticity proven via an EdDSA digital signature." ;
    skos:inScheme indimp:AuthProof ;
    skos:prefLabel "EdDSA signature" ;
    skos:topConceptOf indimp:AuthProof .

indimp:equipment a skos:Concept ;
    skos:definition "Technology or measure that is specific equipment." ;
    skos:inScheme indimp:TechMeasType ;
    skos:prefLabel "Equipment" ;
    skos:topConceptOf indimp:TechMeasType .

indimp:facility a skos:Concept ;
    skos:definition "Technology or measure that is categorized as a facility." ;
    skos:inScheme indimp:TechMeasType ;
    skos:prefLabel "Facility" ;
    skos:topConceptOf indimp:TechMeasType .

indimp:intentional a skos:Concept ;
    skos:definition "Impact that was deliberately intended." ;
    skos:inScheme indimp:ImpactIntentionality ;
    skos:prefLabel "Intentional" ;
    skos:topConceptOf indimp:ImpactIntentionality .

indimp:fixed-ex-ante a skos:Concept ;
    skos:definition "Parameter or data point whose value is determined and fixed prior to the start of the crediting period." ;
    skos:inScheme indimp:MonitoredOrFixed ;
    skos:prefLabel "Fixed ex-ante" ;
    skos:topConceptOf indimp:MonitoredOrFixed .

indimp:monitored a skos:Concept ;
    skos:definition "Parameter or data point whose value is determined through ongoing monitoring during the crediting period." ;
    skos:inScheme indimp:MonitoredOrFixed ;
    skos:prefLabel "Monitored" ;
    skos:topConceptOf indimp:MonitoredOrFixed .

indimp:mr-verifier a skos:Concept ;
    skos:definition "License scope permitting verification of monitoring reports." ;
    skos:inScheme indimp:LicenseScope ;
    skos:prefLabel "MR verifier" ;
    skos:topConceptOf indimp:LicenseScope .

indimp:no a skos:Concept ;
    skos:definition "Impact will not be monitored." ;
    skos:inScheme indimp:MonitoringStatus ;
    skos:prefLabel "No" ;
    skos:topConceptOf indimp:MonitoringStatus .

indimp:none a skos:Concept ;
    skos:definition "No authenticity proof is provided." ;
    skos:inScheme indimp:AuthProof ;
    skos:prefLabel "None" ;
    skos:topConceptOf indimp:AuthProof .

indimp:other a skos:Concept ;
    skos:definition "Technology or measure subtype not captured by the other categories." ;
    skos:inScheme indimp:TechMeasType ;
    skos:prefLabel "Other" ;
    skos:topConceptOf indimp:TechMeasType .

indimp:pdd-validator a skos:Concept ;
    skos:definition "License scope permitting validation of project design documents." ;
    skos:inScheme indimp:LicenseScope ;
    skos:prefLabel "PDD validator" ;
    skos:topConceptOf indimp:LicenseScope .

indimp:project-developer a skos:Concept ;
    skos:definition "License scope permitting project development activities." ;
    skos:inScheme indimp:LicenseScope ;
    skos:prefLabel "Project developer" ;
    skos:topConceptOf indimp:LicenseScope .

indimp:rsa-signature a skos:Concept ;
    skos:definition "Authenticity proven via an RSA digital signature." ;
    skos:inScheme indimp:AuthProof ;
    skos:prefLabel "RSA signature" ;
    skos:topConceptOf indimp:AuthProof .

indimp:standard-registry a skos:Concept ;
    skos:definition "Platform user that acts as a standard registry." ;
    skos:inScheme indimp:UserType ;
    skos:prefLabel "Standard registry" ;
    skos:topConceptOf indimp:UserType .

indimp:system a skos:Concept ;
    skos:definition "Technology or measure that operates as a system." ;
    skos:inScheme indimp:TechMeasType ;
    skos:prefLabel "System" ;
    skos:topConceptOf indimp:TechMeasType .

indimp:unintentional a skos:Concept ;
    skos:definition "Impact that occurred without being deliberately intended." ;
    skos:inScheme indimp:ImpactIntentionality ;
    skos:prefLabel "Unintentional" ;
    skos:topConceptOf indimp:ImpactIntentionality .

indimp:user a skos:Concept ;
    skos:definition "General platform user." ;
    skos:inScheme indimp:UserType ;
    skos:prefLabel "User" ;
    skos:topConceptOf indimp:UserType .

indimp:vc a skos:Concept ;
    skos:definition "Authenticity proven via a verifiable credential." ;
    skos:inScheme indimp:AuthProof ;
    skos:prefLabel "Verifiable credential" ;
    skos:topConceptOf indimp:AuthProof .

indimp:yes a skos:Concept ;
    skos:definition "Impact will be monitored." ;
    skos:inScheme indimp:MonitoringStatus ;
    skos:prefLabel "Yes" ;
    skos:topConceptOf indimp:MonitoringStatus .

indimp:BeneficialOrAdverse a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether an impact is beneficial or adverse." ;
    skos:hasTopConcept indimp:adverse,
        indimp:beneficial ;
    skos:prefLabel "Impact benefit classification" .

indimp:ImpactIntentionality a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether an impact was intentional or unintentional." ;
    skos:hasTopConcept indimp:intentional,
        indimp:unintentional ;
    skos:prefLabel "Impact intentionality" .

indimp:MonitoringStatus a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether an impact will be monitored." ;
    skos:hasTopConcept indimp:no,
        indimp:yes ;
    skos:prefLabel "Impact monitoring status" .

indimp:UserType a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary of Independent Impact platform user types." ;
    skos:hasTopConcept indimp:standard-registry,
        indimp:user ;
    skos:prefLabel "Independent Impact user types" .

indimp:LicenseScope a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary of scopes for Independent Impact Agent Licenses." ;
    skos:hasTopConcept indimp:mr-verifier,
        indimp:pdd-validator,
        indimp:project-developer ;
    skos:prefLabel "Independent Impact license scopes" .

indimp:AuthProof a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary describing how document authenticity is proven." ;
    skos:hasTopConcept indimp:eddsa-signature,
        indimp:none,
        indimp:rsa-signature,
        indimp:vc ;
    skos:prefLabel "Document authenticity proof mechanisms" .

indimp:TechMeasType a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for subtypes of technologies or measures used in projects or activities." ;
    skos:hasTopConcept indimp:equipment,
        indimp:facility,
        indimp:other,
        indimp:system ;
    skos:prefLabel "Technology or measure subtypes" .

indimp:MonitoredOrFixed a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether a data parameter will be monitored during the crediting period or fixed ex-ante." ;
    skos:hasTopConcept indimp:fixed-ex-ante,
        indimp:monitored ;
    skos:prefLabel "Monitored or fixed ex-ante" .

