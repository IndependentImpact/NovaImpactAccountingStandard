@prefix aiao: <http://w3id.org/aiao#> .
@prefix claimont: <http://w3id.org/claimont#> .
@prefix data: <https://jellyfiiish.xyz/ns/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hedera: <https://hashgraphontology.xyz/core/> .
@prefix impactont: <http://w3id.org/impactont#> .
@prefix infocomm: <http://w3id.org/infocomm#> .
@prefix ind: <http://independentimpact.org/indicator-owl/> .
@prefix meth: <http://independentimpact.org/methodology/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vcdm: <https://www.w3.org/ns/credentials/v2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nias-o: a owl:Ontology ;
    rdfs:label "Nova Impact Accounting Standard Ontology"@en ;
    rdfs:comment "Ontology for the Nova Impact Accounting Standard"@en ;
    dcterms:title "Nova Impact Accounting Standard Ontology"@en ;
    dcterms:description "Ontology for the Nova Impact Accounting Standard"@en ;
    owl:imports <http://independentimpact.org/methont/methont.ttl/1.1.0> ;
    owl:imports <http://w3id.org/aiao> ;
    owl:imports <http://w3id.org/claimont> ;
    owl:imports <http://w3id.org/impactont> ;
    owl:imports <http://w3id.org/infocomm> ;
    owl:imports <https://hashgraphontology.xyz/consensus> ;
    owl:imports <https://hashgraphontology.xyz/core> .

data:Document rdfs:subClassOf infocomm:Information .

hedera:ConsensusTopic rdfs:subClassOf infocomm:Medium .

nias-o:OperationalVocabularyTerm a owl:Class ;
    rdfs:label "OperationalVocabularyTerm"@en ;
    rdfs:subClassOf skos:Concept ;
    skos:definition "A domain-specific controlled vocabulary term that is also published as a SKOS concept for labelling, display, and catalogue management."@en .

nias-o:AuthenticityProofMethod a owl:Class ;
    rdfs:label "AuthenticityProofMethod"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A method by which the authenticity of a document can be proven."@en .

nias-o:DataParameterMonitoringMode a owl:Class ;
    rdfs:label "DataParameterMonitoringMode"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled mode indicating whether a data or parameter value is monitored during the crediting period or fixed ex-ante."@en .

nias-o:ImpactBenefitClassification a owl:Class ;
    rdfs:label "ImpactBenefitClassification"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled classification indicating whether an impact is beneficial or adverse."@en .

nias-o:ImpactIntentionality a owl:Class ;
    rdfs:label "ImpactIntentionality"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled classification indicating whether an impact is intentional or unintentional."@en .

nias-o:LicenseScope a owl:Class ;
    rdfs:label "LicenseScope"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled scope for an agent license or license application."@en .

nias-o:MethodologyApprovalStatus a owl:Class ;
    rdfs:label "MethodologyApprovalStatus"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled approval status for a methodology within the Nova Impact Accounting Standard."@en .

nias-o:PublicPrivateClassification a owl:Class ;
    rdfs:label "PublicPrivateClassification"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled classification indicating whether a project party is public-sector or private-sector."@en .

nias-o:ReportStatus a owl:Class ;
    rdfs:label "ReportStatus"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled lifecycle status for report content or impact estimates."@en .

nias-o:ReviewDecision a owl:Class ;
    rdfs:label "ReviewDecision"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled decision made during document or field review."@en .

nias-o:ReviewMandate a owl:Class ;
    rdfs:label "ReviewMandate"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled review mandate such as validation or verification."@en .

nias-o:ScoringModelTerm a owl:Class ;
    rdfs:label "ScoringModelTerm"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled term used in the activity scoring model."@en .

nias-o:ScoreType a owl:Class ;
    rdfs:label "ScoreType"@en ;
    rdfs:subClassOf nias-o:ScoringModelTerm ;
    skos:definition "A controlled term identifying a type of score in the scoring model."@en .

nias-o:ScoringRule a owl:Class ;
    rdfs:label "ScoringRule"@en ;
    rdfs:subClassOf nias-o:ScoringModelTerm ;
    skos:definition "A controlled term identifying a rule or adjustment used in scoring."@en .

nias-o:ScoringUnit a owl:Class ;
    rdfs:label "ScoringUnit"@en ;
    rdfs:subClassOf nias-o:ScoringModelTerm ;
    skos:definition "A controlled term identifying a unit awarded or counted by the scoring model."@en .

nias-o:TechnologyMeasureType a owl:Class ;
    rdfs:label "TechnologyMeasureType"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled subtype of a technology or measure used in a project or activity."@en .

nias-o:QualityDimension a owl:Class ;
    rdfs:label "QualityDimension"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled quality dimension used to assess indicators, methodologies, instruments, or similar assessment objects."@en .

nias-o:IndicatorQualityDimension a owl:Class ;
    rdfs:label "IndicatorQualityDimension"@en ;
    rdfs:subClassOf nias-o:QualityDimension ;
    skos:definition "A controlled quality dimension for assessing impact indicators."@en .

nias-o:MethodologyQualityDimension a owl:Class ;
    rdfs:label "MethodologyQualityDimension"@en ;
    rdfs:subClassOf nias-o:QualityDimension ;
    skos:definition "A controlled quality dimension for assessing methodologies."@en .

nias-o:InstrumentQualityDimension a owl:Class ;
    rdfs:label "InstrumentQualityDimension"@en ;
    rdfs:subClassOf nias-o:QualityDimension ;
    skos:definition "A controlled quality dimension for assessing measurement instruments."@en .

nias-o:ReputationLifecycleTerm a owl:Class ;
    rdfs:label "ReputationLifecycleTerm"@en ;
    rdfs:subClassOf nias-o:OperationalVocabularyTerm ;
    skos:definition "A controlled term describing the lifecycle dynamics of Knowledge and Skills Reputation."@en .

nias-o:AgentActivityWorkflowRelation a owl:Class ;
    rdfs:label "AgentActivityWorkflowRelation"@en ;
    rdfs:subClassOf aiao:AgentActivityRelation ;
    skos:definition "Relates an agent to an activity in the context of a specific workflow."@en .

nias-o:AgentLicense a owl:Class ;
    rdfs:label "AgentLicense"@en ;
    rdfs:subClassOf vcdm:VerifiableCredential ;
    skos:definition "A license that allows a platform user to perform specialised actions on the Nova Impact Accounting Standard platform."@en .

nias-o:CreditingPeriod a owl:Class ;
    rdfs:label "CreditingPeriod"@en ;
    rdfs:subClassOf time:Interval ;
    skos:definition "A crediting period for a monitored impact."@en .

nias-o:DocumentSchema a owl:Class ;
    rdfs:label "DocumentSchema"@en ;
    rdfs:subClassOf dcterms:Resource,
        aiao:Control ;
    skos:definition "A specification for the structure and data types of a document."@en .

nias-o:DataParameterRequirement a owl:Class ;
    rdfs:label "DataParameterRequirement"@en ;
    rdfs:subClassOf infocomm:Information ;
    skos:definition "A data or parameter requirement used to quantify an impact."@en .

nias-o:Dataset a owl:Class ;
    rdfs:label "Dataset"@en ;
    rdfs:subClassOf dcterms:Resource ;
    skos:definition "A dataset used as evidence or input data in a monitoring report calculation."@en .

nias-o:DataLineageReport a owl:Class ;
    rdfs:label "DataLineageReport"@en ;
    rdfs:subClassOf data:Document,
        claimont:Report ;
    skos:definition "A workflow document reporting provenance for raw, transferred, cleaned, and final dataset artifacts used in monitoring report calculations."@en .

nias-o:DocumentFieldReview a owl:Class ;
    rdfs:label "DocumentFieldReview"@en ;
    rdfs:subClassOf infocomm:Information ;
    skos:definition "A field-level review finding that records the reviewed field, copied source response, reviewer decision, and reviewer feedback."@en .

nias-o:DocumentReference a owl:Class ;
    rdfs:label "DocumentReference"@en ;
    rdfs:subClassOf dcterms:Resource ;
    skos:definition "A compact reference to a document using its workflow message identifier and content-addressed resource location."@en .

nias-o:DocumentReview a owl:Class ;
    rdfs:label "DocumentReview"@en ;
    rdfs:subClassOf data:Document,
        claimont:Attestation ;
    skos:definition "A workflow document that attests to a review decision over another document using one or more field-level review findings."@en .

nias-o:EntityXhederaTopicLink a owl:Class ;
    rdfs:label "EntityXhederaTopicLink"@en ;
    rdfs:subClassOf owl:Thing ;
    skos:definition "Links a Nova Impact Accounting Standard entity (user, project, methodology, etc.) to a Hedera topic."@en .

nias-o:ImpactDeclaration a owl:Class ;
    rdfs:label "ImpactDeclaration"@en ;
    rdfs:subClassOf claimont:Report ;
    skos:definition "A report-like declaration of one or more impacts for a project design document section."@en .

nias-o:ImpactSummary a owl:Class ;
    rdfs:label "ImpactSummary"@en ;
    rdfs:subClassOf infocomm:Information ;
    skos:definition "A compact summary of a verified impact, including description, period, unit, and measured extent."@en .

nias-o:Methodology a owl:Class ;
    rdfs:label "Methodology"@en ;
    rdfs:subClassOf meth:Methodology,
        aiao:Control ;
    owl:deprecated true ;
    skos:definition "Deprecated NIAS-local methodology bridge. Use meth:Methodology from the Methodology Ontology for canonical methodology resources."@en .

nias-o:MonitoringReport a owl:Class ;
    rdfs:label "MonitoringReport"@en ;
    rdfs:subClassOf data:Document ;
    skos:definition "A monitoring report documenting the measured impacts of a project activity for a specific crediting period."@en .

nias-o:GenericDocumentReview a owl:Class ;
    rdfs:label "GenericDocumentReview"@en ;
    rdfs:subClassOf nias-o:DocumentReview ;
    skos:definition "A generic document review workflow document that can review any submitted document."@en .

nias-o:MonitoringImpactReport a owl:Class ;
    rdfs:label "MonitoringImpactReport"@en ;
    rdfs:subClassOf claimont:Report ;
    skos:definition "A report representing the content of a monitoring report for a specific monitoring period, asserting measured impacts of a project as impactont:Impact resources that reference measured states and indicator values. Distinct from the document artifact (nias-o:MonitoringReport) and from the submission event."@en .

nias-o:ProjectDesignDocument a owl:Class ;
    rdfs:label "ProjectDesignDocument"@en ;
    rdfs:subClassOf claimont:Report ;
    skos:definition "A report representing the content of a Project Design Document, asserted by a submitting agent about a project. Models the PDD as an agent-authored report linked to project domain resources rather than as a prov:Plan. A separate prov:Plan node should be used only where the PDD describes intended future implementation or monitoring procedures."@en .

nias-o:PddSectionAReport a owl:Class ;
    rdfs:label "PddSectionAReport"@en ;
    rdfs:subClassOf nias-o:ProjectDesignDocument ;
    skos:definition "A PDD report covering Section A project design content, including project description, parties, location, technologies, and legal matters."@en .

nias-o:PddSectionBReport a owl:Class ;
    rdfs:label "PddSectionBReport"@en ;
    rdfs:subClassOf nias-o:ProjectDesignDocument ;
    skos:definition "A PDD report covering Section B impact declaration content, including declared impacts, states, and methodology linkage."@en .

nias-o:PddSectionCReport a owl:Class ;
    rdfs:label "PddSectionCReport"@en ;
    rdfs:subClassOf nias-o:ProjectDesignDocument ;
    skos:definition "A PDD report covering Section C monitoring and procedural content. Any planned future monitoring or sampling procedures described here may be modelled as a linked prov:Plan."@en .

nias-o:PddCertificateIssuanceRequest a owl:Class ;
    rdfs:label "PddCertificateIssuanceRequest"@en ;
    rdfs:subClassOf data:Document,
        claimont:Report ;
    skos:definition "A workflow request for issuing a PDD certificate after the PDD section validation reports have been approved."@en .

nias-o:PddSectionCStakeholderEngagement a owl:Class ;
    rdfs:label "PddSectionCStakeholderEngagement"@en ;
    rdfs:subClassOf data:Document,
        nias-o:PddSectionCReport ;
    skos:definition "A PDD section C report describing local stakeholder consultation modalities and comments."@en .

nias-o:PlatformUser a owl:Class ;
    rdfs:label "PlatformUser"@en ;
    rdfs:subClassOf infocomm:CommunicationParty ;
    skos:definition "An actor on the Nova Impact Accounting Standard platform."@en .

nias-o:PlatformUserXhederaAccountLink a owl:Class ;
    rdfs:label "PlatformUserXhederaAccountLink"@en ;
    rdfs:subClassOf owl:Thing ;
    skos:definition "Links an Nova Impact Accounting Standard platform user to a Hedera account."@en .

nias-o:ProjectListingApplication a owl:Class ;
    rdfs:label "ProjectListingApplication"@en ;
    rdfs:subClassOf data:Document,
        claimont:Report ;
    skos:definition "An early workflow request by a project developer to list a project in the registry."@en .

nias-o:ProjectParty a owl:Class ;
    rdfs:label "ProjectParty"@en ;
    rdfs:subClassOf aiao:AgentActivityRelation ;
    skos:definition "A party relation for a project, including host, participant, and public/private classification."@en .

nias-o:ResourceArtifact a owl:Class ;
    rdfs:label "ResourceArtifact"@en ;
    rdfs:subClassOf dcterms:Resource ;
    skos:definition "A resource artifact referenced by a workflow document, such as a calculation script, calculation report, impact result, or dataset file."@en .

nias-o:VerifiedImpactCertificate a owl:Class ;
    rdfs:label "VerifiedImpactCertificate"@en ;
    rdfs:subClassOf vcdm:VerifiableCredential,
        dcterms:Resource ;
    skos:definition "A verified impact certificate issued for a measured and approved impact over a defined impact period."@en .

nias-o:VerifiedImpactCertificateIssuanceRequest a owl:Class ;
    rdfs:label "VerifiedImpactCertificateIssuanceRequest"@en ;
    rdfs:subClassOf data:Document,
        claimont:Report ;
    skos:definition "A workflow request for issuing a verified impact certificate based on an approved monitoring report review and impact summary."@en .

nias-o:VerifiedImpactCertificateIssuanceRequestReview a owl:Class ;
    rdfs:label "VerifiedImpactCertificateIssuanceRequestReview"@en ;
    rdfs:subClassOf nias-o:DocumentReview ;
    skos:definition "A document review workflow document for a verified impact certificate issuance request."@en .

nias-o:TechnologyOrMeasure a owl:Class ;
    rdfs:label "TechnologyOrMeasure"@en ;
    rdfs:subClassOf aiao:Instrument ;
    skos:definition "A measure or a type of technology that will be implemented or employed by a project or an activity to achieve its purpose."@en .

nias-o:Workflow a owl:Class ;
    rdfs:label "Workflow"@en ;
    rdfs:subClassOf aiao:Control ;
    skos:definition "A set of actions, processes or procedures that must be executed or performed to achieve a specific outcome."@en .

nias-o:WorkflowDocumentSubmission a owl:Class ;
    rdfs:label "WorkflowDocumentSubmission"@en ;
    rdfs:subClassOf infocomm:CommunicationEvent ;
    skos:definition "Records the communication event in which a document is submitted to a specific step of a specific workflow for a specific workflow subject."@en .

nias-o:WorkflowStep a owl:Class ;
    rdfs:label "WorkflowStep"@en ;
    rdfs:subClassOf aiao:Control ;
    skos:definition "A single action, process or procedure of a workflow."@en .

nias-o:additionalInfo a owl:DatatypeProperty ;
    rdfs:label "additionalInfo"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    skos:definition "Any additional information about a thing."@en .

nias-o:additionalityJustification a owl:DatatypeProperty ;
    rdfs:label "additionalityJustification"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range xsd:string ;
    skos:definition "A justification for why an impact is considered additional."@en .

nias-o:authProof a owl:ObjectProperty ;
    rdfs:label "authProof"@en ;
    rdfs:domain data:Document ;
    rdfs:range nias-o:AuthenticityProofMethod ;
    skos:definition "The mechanism by which the authenticity of a document can be proven."@en .

nias-o:beneficialOrAdverse a owl:ObjectProperty ;
    rdfs:label "beneficialOrAdverse"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range nias-o:ImpactBenefitClassification ;
    skos:definition "Indicates whether an impact of a project or an activity (whether intended or unintended) was an environmentally beneficial or environmentally adverse impact."@en .

nias-o:createdBy a owl:ObjectProperty ;
    rdfs:label "createdBy"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range nias-o:PlatformUser ;
    skos:definition "The Nova Impact Accounting Standard platform user who created the project."@en .

nias-o:creditingPeriod a owl:ObjectProperty ;
    rdfs:label "creditingPeriod"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range nias-o:CreditingPeriod ;
    skos:definition "A crediting period for an impact. Must cover at least one monitoring period."@en .

nias-o:creditingPeriodIsRenewable a owl:DatatypeProperty ;
    rdfs:label "creditingPeriodIsRenewable"@en ;
    rdfs:domain nias-o:CreditingPeriod ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether a crediting period is renewable or not."@en .

nias-o:currentAgeInYears a owl:DatatypeProperty ;
    rdfs:label "currentAgeInYears"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:decimal ;
    skos:definition "The age of a thing, given in years, at the time of reporting."@en .

nias-o:dateCreated a owl:DatatypeProperty ;
    rdfs:label "dateCreated"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:dateTime ;
    skos:definition "The timestamp at which a project was created on the Nova Impact Accounting Standard platform."@en .

nias-o:dateRegistered a owl:DatatypeProperty ;
    rdfs:label "dateRegistered"@en ;
    rdfs:domain nias-o:PlatformUser ;
    rdfs:range xsd:dateTime ;
    skos:definition "The timestamp at which a user account was created on the Nova Impact Accounting Standard platform."@en .

nias-o:dataParameterRequirement a owl:ObjectProperty ;
    rdfs:label "dataParameterRequirement"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range nias-o:DataParameterRequirement ;
    skos:definition "A monitored or fixed data or parameter requirement used to quantify an impact."@en .

nias-o:dataParameterPurpose a owl:DatatypeProperty ;
    rdfs:label "dataParameterPurpose"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:string ;
    skos:definition "Explains why a data or parameter requirement is needed for impact quantification."@en .

nias-o:dataSource a owl:DatatypeProperty ;
    rdfs:label "dataSource"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:string ;
    skos:definition "Source used for a fixed ex-ante data or parameter value."@en .

nias-o:debundlingAssessment a owl:DatatypeProperty ;
    rdfs:label "debundlingAssessment"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:string ;
    skos:definition "Assessment of whether a project has been debundled from a larger project or activity."@en .

nias-o:didDocument a owl:ObjectProperty ;
    rdfs:label "didDocument"@en ;
    rdfs:domain nias-o:PlatformUser ;
    rdfs:range data:Document ;
    skos:definition "The document providing a platform user's DID and its associated properties."@en .

nias-o:documentAuthor a owl:AnnotationProperty ;
    rdfs:label "author"@en ;
    rdfs:domain data:Document ;
    rdfs:range [ owl:unionOf ( nias-o:PlatformUser aiao:Agent rdfs:Literal ) ] ;
    skos:definition "Identifies an entity responsible for the creation of the content of a document."@en .

nias-o:documentSchema a owl:ObjectProperty ;
    rdfs:label "documentSchema"@en ;
    rdfs:domain data:Document ;
    rdfs:range nias-o:DocumentSchema ;
    skos:definition "A schema specifying the format and structure that a document must adhere to."@en .

nias-o:validatingShape a owl:ObjectProperty ;
    rdfs:label "validatingShape"@en ;
    rdfs:domain nias-o:DocumentSchema ;
    rdfs:range sh:NodeShape ;
    skos:definition "The SHACL node shape that validates data claiming conformance to a document schema."@en .

nias-o:entityXhederaTopicLinkDescription a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:domain nias-o:EntityXhederaTopicLink ;
    rdfs:range xsd:string ;
    skos:definition "A description of the link between an entity and a Hedera topic, e.g., 'DID'."@en .

nias-o:estimatedLifespanInYears a owl:DatatypeProperty ;
    rdfs:label "estimatedLifespanInYears"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:decimal ;
    skos:definition "The estimated lifespan of a thing, given in years."@en .

nias-o:eligibilityDescription a owl:DatatypeProperty ;
    rdfs:label "eligibilityDescription"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:string ;
    skos:definition "Narrative description of project eligibility under the applicable standard or methodology."@en .

nias-o:exAnteImpactEstimate a owl:DatatypeProperty ;
    rdfs:label "exAnteImpactEstimate"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range xsd:decimal ;
    skos:definition "Expected ex-ante impact quantity for project validation or design-stage declaration."@en .

nias-o:hasAgentLicense a owl:ObjectProperty ;
    rdfs:label "hasAgentLicense"@en ;
    rdfs:domain nias-o:PlatformUser ;
    rdfs:range nias-o:AgentLicense ;
    skos:definition "An Nova Impact Accounting Standard Agent License held by a platform user."@en .

nias-o:hasVerifiableCredential a owl:ObjectProperty ;
    rdfs:label "hasVerifiableCredential"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:PlatformUser aiao:Activity aiao:Project ) ] ;
    rdfs:range vcdm:VerifiableCredential ;
    skos:definition "A verifiable credential document held by an entity (e.g., by a user or an activity)."@en .

nias-o:hasWorkflowStep a owl:ObjectProperty ;
    rdfs:label "Workflow"@en ;
    rdfs:domain nias-o:Workflow ;
    rdfs:range nias-o:WorkflowStep ;
    skos:definition "A specific step of a workflow."@en .

nias-o:hasWorkflowSubmission a owl:ObjectProperty ;
    rdfs:label "hasWorkflowSubmission"@en ;
    rdfs:comment "Provides details about a workflow submission for the document in question." ;
    rdfs:domain data:Document ;
    rdfs:range nias-o:WorkflowDocumentSubmission .

nias-o:hederaAccount a owl:ObjectProperty ;
    rdfs:label "hederaAccount"@en ;
    rdfs:domain nias-o:PlatformUserXhederaAccountLink ;
    rdfs:range hedera:Account ;
    skos:definition "A Hedera account."@en .

nias-o:hederaTopic a owl:ObjectProperty ;
    rdfs:label "hederaTopic"@en ;
    rdfs:domain nias-o:EntityXhederaTopicLink ;
    rdfs:range hedera:ConsensusTopic ;
    skos:definition "A Hedera Consensus Service topic."@en .

nias-o:hasDeclaredImpact a owl:ObjectProperty ;
    rdfs:label "hasDeclaredImpact"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:ImpactDeclaration nias-o:PddSectionBReport ) ] ;
    rdfs:range impactont:Impact ;
    skos:definition "Links an impact declaration to an impact that it declares."@en .

nias-o:impactIntentionality a owl:ObjectProperty ;
    rdfs:label "intentionality"@en ;
    rdfs:comment "An unintentional impact (whether beneficial or adverse) is typically referred to as 'leakage'." ;
    rdfs:domain impactont:Impact ;
    rdfs:range nias-o:ImpactIntentionality ;
    skos:definition "Indicates whether an of a project or activity was an intentional or an unintentional impact."@en .

nias-o:impactClaim a owl:ObjectProperty ;
    rdfs:label "impactClaim"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:ImpactDeclaration claimont:Report ) ] ;
    rdfs:range aiao:ImpactClaim ;
    skos:definition "Links a report or impact declaration to an impact claim about the project or activity."@en .

nias-o:isEncrypted a owl:DatatypeProperty ;
    rdfs:label "isEncrypted"@en ;
    rdfs:domain dcterms:Resource ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether the content of a resource is encrypted."@en .

nias-o:isLinkedToHederaAccount a owl:ObjectProperty ;
    rdfs:label "isLinkedToHederaAccount"@en ;
    rdfs:comment "Links an Nova Impact Accounting Standard platform user to a Hedera account." ;
    rdfs:domain nias-o:PlatformUser ;
    rdfs:range nias-o:PlatformUserXhederaAccountLink .

nias-o:isLinkedToHederaTopic a owl:ObjectProperty ;
    rdfs:label "isLinkedToHederaTopic"@en ;
    rdfs:comment "Links an Nova Impact Accounting Standard entity to a Hedera topic." ;
    rdfs:domain nias-o:PlatformUser ;
    rdfs:range nias-o:EntityXhederaTopicLink .

nias-o:isReviewOf a owl:ObjectProperty ;
    rdfs:label "isReviewOf"@en ;
    rdfs:comment "Identifies a document as a review of another document." ;
    rdfs:domain data:Document ;
    rdfs:range data:Document .

nias-o:isHostParty a owl:DatatypeProperty ;
    rdfs:label "isHostParty"@en ;
    rdfs:domain nias-o:ProjectParty ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether a project party is a host party."@en .

nias-o:isParticipantParty a owl:DatatypeProperty ;
    rdfs:label "isParticipantParty"@en ;
    rdfs:domain nias-o:ProjectParty ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether a project party participates in the project."@en .

nias-o:legalMatters a owl:DatatypeProperty ;
    rdfs:label "legalMatters"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:string ;
    skos:definition "Legal matters relevant to the project design."@en .

nias-o:licenseNumber a owl:DatatypeProperty ;
    rdfs:label "licenseNumber"@en ;
    rdfs:domain nias-o:AgentLicense ;
    rdfs:range xsd:string ;
    skos:definition "A unique string identifier for an Nova Impact Accounting Standard Agent License."@en .

nias-o:licenseScope a owl:ObjectProperty ;
    rdfs:label "licenseScope"@en ;
    # Domain includes both the issued license class and the application/review
    # classes which are defined later in this file (ordering is irrelevant in OWL).
    rdfs:domain [ owl:unionOf ( nias-o:AgentLicense nias-o:LicenseApplication nias-o:LicenseApplicationReview ) ] ;
    rdfs:range nias-o:LicenseScope ;
    skos:definition "The set of actions that the holder of the license is allowed to perform on the Nova Impact Accounting Standard platform. Also used on license applications and reviews to record the scope applied for."@en .

nias-o:locationShapefile a owl:ObjectProperty ;
    rdfs:label "locationShapefile"@en ;
    rdfs:subPropertyOf impactont:hasSpatialLocation ;
    rdfs:domain [ owl:unionOf ( aiao:Activity aiao:Project ) ] ;
    rdfs:range impactont:SpatialLocation ;
    owl:deprecated true ;
    skos:definition "Deprecated legacy property. Use impactont:hasSpatialLocation with impactont:SpatialLocation instances for spatial objects, and attach NIAS resource metadata to those instances when needed."@en .

nias-o:monitored a owl:DatatypeProperty ;
    rdfs:label "monitored"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether an impact of a project or an activity will be monitored or not."@en .

nias-o:monitoringPeriod a owl:ObjectProperty ;
    rdfs:label "monitoringPeriod"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range time:Interval ;
    skos:definition "A monitoring period for an impact."@en .

nias-o:monitoredOrFixed a owl:ObjectProperty ;
    rdfs:label "monitoredOrFixed"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range nias-o:DataParameterMonitoringMode ;
    skos:definition "Indicates whether a data or parameter value is monitored or fixed ex-ante."@en .

nias-o:alignedWithPDD a owl:ObjectProperty ;
    rdfs:label "alignedWithPDD"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range data:Document ;
    skos:definition "The project design document (PDD) on which a monitoring report is based."@en .

nias-o:forPeriod a owl:ObjectProperty ;
    rdfs:label "forPeriod"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:MonitoringReport nias-o:DataLineageReport ) ] ;
    rdfs:range time:Interval ;
    skos:definition "The monitoring period (falling within the crediting period) for which a monitoring report is valid."@en .

nias-o:hasMonitoringReport a owl:ObjectProperty ;
    rdfs:label "hasMonitoringReport"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range nias-o:MonitoringReport ;
    skos:definition "A monitoring report associated with a project."@en .

nias-o:certificateNumber a owl:DatatypeProperty ;
    rdfs:label "certificateNumber"@en ;
    rdfs:domain nias-o:VerifiedImpactCertificate ;
    rdfs:range xsd:string ;
    skos:definition "Human- or registry-readable identifier for an issued verified impact certificate."@en .

nias-o:calculationCode a owl:ObjectProperty ;
    rdfs:label "calculationCode"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "Calculation code or executable notebook used to calculate the measured impact reported by a monitoring report."@en .

nias-o:calculationReport a owl:ObjectProperty ;
    rdfs:label "calculationReport"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "Report produced by the calculation process used for a monitoring report."@en .

nias-o:dataLineageReview a owl:ObjectProperty ;
    rdfs:label "dataLineageReview"@en ;
    rdfs:domain nias-o:Dataset ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Approved document review for the data lineage report governing a dataset."@en .

nias-o:dataCleaningCode a owl:ObjectProperty ;
    rdfs:label "dataCleaningCode"@en ;
    rdfs:domain nias-o:DataLineageReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "RMD, script, or executable artifact that produced the final cleaned dataset."@en .

nias-o:dataCleaningReport a owl:ObjectProperty ;
    rdfs:label "dataCleaningReport"@en ;
    rdfs:domain nias-o:DataLineageReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "Report produced by the data cleaning process for a data lineage report."@en .

nias-o:dataTransferCode a owl:ObjectProperty ;
    rdfs:label "dataTransferCode"@en ;
    rdfs:domain nias-o:DataLineageReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "RMD, script, or executable artifact that transferred or anonymized raw data into the data lineage process."@en .

nias-o:dataTransferReport a owl:ObjectProperty ;
    rdfs:label "dataTransferReport"@en ;
    rdfs:domain nias-o:DataLineageReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "Report produced by the data transfer and anonymization process for a data lineage report."@en .

nias-o:documentMessageId a owl:DatatypeProperty ;
    rdfs:label "documentMessageId"@en ;
    rdfs:domain nias-o:DocumentReference ;
    rdfs:range xsd:string ;
    skos:definition "Legacy workflow message identifier for a referenced document."@en .

nias-o:fieldKey a owl:DatatypeProperty ;
    rdfs:label "fieldKey"@en ;
    rdfs:domain nias-o:DocumentFieldReview ;
    rdfs:range xsd:string ;
    skos:definition "Legacy key of the reviewed document field."@en .

nias-o:fieldPrompt a owl:DatatypeProperty ;
    rdfs:label "fieldPrompt"@en ;
    rdfs:domain nias-o:DocumentFieldReview ;
    rdfs:range xsd:string ;
    skos:definition "Original prompt shown for the reviewed document field."@en .

nias-o:fieldReview a owl:ObjectProperty ;
    rdfs:label "fieldReview"@en ;
    rdfs:domain nias-o:DocumentReview ;
    rdfs:range nias-o:DocumentFieldReview ;
    skos:definition "A field-level review finding included in a document review."@en .

nias-o:fieldTitle a owl:DatatypeProperty ;
    rdfs:label "fieldTitle"@en ;
    rdfs:domain nias-o:DocumentFieldReview ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable title of the reviewed document field."@en .

nias-o:finalDatasetArtifact a owl:ObjectProperty ;
    rdfs:label "finalDatasetArtifact"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:Dataset nias-o:DataLineageReport ) ] ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "The final approved dataset artifact used in a monitoring report calculation."@en .

nias-o:finalReviewDecision a owl:ObjectProperty ;
    rdfs:label "finalReviewDecision"@en ;
    rdfs:domain nias-o:DocumentReview ;
    rdfs:range nias-o:ReviewDecision ;
    skos:definition "Final approve/reject decision for a document review."@en .

nias-o:impactDescription a owl:DatatypeProperty ;
    rdfs:label "impactDescription"@en ;
    rdfs:domain nias-o:ImpactSummary ;
    rdfs:range xsd:string ;
    skos:definition "Legacy impact summary description."@en .

nias-o:impactIndicatorLabel a owl:DatatypeProperty ;
    rdfs:label "impactIndicatorLabel"@en ;
    rdfs:domain nias-o:VerifiedImpactCertificate ;
    rdfs:range xsd:string ;
    skos:definition "Legacy impact indicator label shown on a verified impact certificate."@en .

nias-o:impactSummary a owl:ObjectProperty ;
    rdfs:label "impactSummary"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:VerifiedImpactCertificate nias-o:VerifiedImpactCertificateIssuanceRequest ) ] ;
    rdfs:range nias-o:ImpactSummary ;
    skos:definition "Summarized impact values used in a verified impact certificate or issuance request."@en .

nias-o:impactResultResource a owl:ObjectProperty ;
    rdfs:label "impactResultResource"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "Machine-readable resource containing the impact calculation result reported by a monitoring report."@en .

nias-o:pddSectionAValidationReview a owl:ObjectProperty ;
    rdfs:label "pddSectionAValidationReview"@en ;
    rdfs:domain nias-o:PddCertificateIssuanceRequest ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Reference to the approved validation review for PDD section A."@en .

nias-o:pddSectionBValidationReview a owl:ObjectProperty ;
    rdfs:label "pddSectionBValidationReview"@en ;
    rdfs:domain nias-o:PddCertificateIssuanceRequest ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Reference to the approved validation review for PDD section B."@en .

nias-o:pddSectionCValidationReview a owl:ObjectProperty ;
    rdfs:label "pddSectionCValidationReview"@en ;
    rdfs:domain nias-o:PddCertificateIssuanceRequest ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Reference to the approved validation review for PDD section C."@en .

nias-o:reportedIndicatorLabel a owl:DatatypeProperty ;
    rdfs:label "reportedIndicatorLabel"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range xsd:string ;
    skos:definition "Legacy indicator label captured on a monitoring report before or alongside normalization to a stable indicator definition IRI."@en .

nias-o:reportedObservation a owl:ObjectProperty ;
    rdfs:label "reportedObservation"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range ind:IndicatorObservation ;
    skos:definition "Indicator observation carrying the measured impact value, unit, period, and observed indicator for a monitoring report."@en .

nias-o:requestedIssuanceAccountId a owl:DatatypeProperty ;
    rdfs:label "requestedIssuanceAccountId"@en ;
    # Domain includes all document types that carry a Hedera shard.realm.num account
    # reference: issuance request documents (PddCIR, MR, VICIR, DRVICIR) identify
    # the account to receive the certificate or token; LicenseApplication and
    # LicenseApplicationReview identify the account to receive the issued license;
    # AgentDetails records the agent's own registered Hedera account.
    rdfs:domain [ owl:unionOf ( nias-o:AgentDetails nias-o:LicenseApplication nias-o:LicenseApplicationReview nias-o:PddCertificateIssuanceRequest nias-o:MonitoringReport nias-o:VerifiedImpactCertificateIssuanceRequest nias-o:VerifiedImpactCertificateIssuanceRequestReview ) ] ;
    rdfs:range xsd:string ;
    skos:definition "Legacy Hedera shard.realm.num account identifier to which a requested certificate or token issuance should be made, or the agent's registered Hedera account identifier in an agent details submission."@en .

nias-o:monitoringReportReview a owl:ObjectProperty ;
    rdfs:label "monitoringReportReview"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:VerifiedImpactCertificate nias-o:VerifiedImpactCertificateIssuanceRequest ) ] ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Approved document review of the monitoring report that supports a verified impact certificate or issuance request."@en .

nias-o:originalResponse a owl:DatatypeProperty ;
    rdfs:label "originalResponse"@en ;
    rdfs:domain nias-o:DocumentFieldReview ;
    rdfs:range xsd:string ;
    skos:definition "Copied original response supplied by the document author for the reviewed field."@en .

nias-o:rawDatasetArtifact a owl:ObjectProperty ;
    rdfs:label "rawDatasetArtifact"@en ;
    rdfs:domain nias-o:DataLineageReport ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "Raw or anonymized dataset artifact used as the input to a data lineage process."@en .

nias-o:reviewerDecision a owl:ObjectProperty ;
    rdfs:label "reviewerDecision"@en ;
    rdfs:domain nias-o:DocumentFieldReview ;
    rdfs:range nias-o:ReviewDecision ;
    skos:definition "Reviewer decision for one field-level review finding."@en .

nias-o:reviewerFeedback a owl:DatatypeProperty ;
    rdfs:label "reviewerFeedback"@en ;
    rdfs:domain nias-o:DocumentFieldReview ;
    rdfs:range xsd:string ;
    skos:definition "Reviewer feedback for one field-level review finding."@en .

nias-o:stakeholderCommentConsideration a owl:DatatypeProperty ;
    rdfs:label "stakeholderCommentConsideration"@en ;
    rdfs:domain nias-o:PddSectionCStakeholderEngagement ;
    rdfs:range xsd:string ;
    skos:definition "Description of how stakeholder comments were considered in PDD section C."@en .

nias-o:stakeholderCommentSummary a owl:DatatypeProperty ;
    rdfs:label "stakeholderCommentSummary"@en ;
    rdfs:domain nias-o:PddSectionCStakeholderEngagement ;
    rdfs:range xsd:string ;
    skos:definition "Summary of stakeholder comments received for PDD section C."@en .

nias-o:stakeholderEngagementModalities a owl:DatatypeProperty ;
    rdfs:label "stakeholderEngagementModalities"@en ;
    rdfs:domain nias-o:PddSectionCStakeholderEngagement ;
    rdfs:range xsd:string ;
    skos:definition "Modalities used for local stakeholder consultation in PDD section C."@en .

nias-o:usesDataset a owl:ObjectProperty ;
    rdfs:label "usesDataset"@en ;
    rdfs:domain nias-o:MonitoringReport ;
    rdfs:range nias-o:Dataset ;
    skos:definition "Dataset used in calculating the measured impact reported by a monitoring report."@en .

nias-o:notMonitoredJustification a owl:DatatypeProperty ;
    rdfs:label "notMonitoredJustification"@en ;
    rdfs:domain impactont:Impact ;
    rdfs:range xsd:string ;
    skos:definition "Provides a justification for why an impact of a project or activity will not be monitored."@en .

nias-o:platformUserXhederaAccountLinkDescription a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:domain nias-o:PlatformUserXhederaAccountLink ;
    rdfs:range xsd:string ;
    skos:definition "A description of the link between a platform user and a Hedera account, e.g., 'PRIMARY_ACCOUNT'."@en .

nias-o:measurementMethodsAndProcedures a owl:DatatypeProperty ;
    rdfs:label "measurementMethodsAndProcedures"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:string ;
    skos:definition "Measurement methods and procedures used for a monitored data or parameter requirement."@en .

nias-o:monitoringFrequency a owl:DatatypeProperty ;
    rdfs:label "monitoringFrequency"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:string ;
    skos:definition "Frequency with which a monitored data or parameter requirement is measured."@en .

nias-o:partyName a owl:DatatypeProperty ;
    rdfs:label "partyName"@en ;
    rdfs:domain nias-o:ProjectParty ;
    rdfs:range xsd:string ;
    skos:definition "Name of a project party."@en .

nias-o:parameterAppliedValue a owl:DatatypeProperty ;
    rdfs:label "parameterAppliedValue"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:decimal ;
    skos:definition "Fixed ex-ante value applied for a data or parameter requirement."@en .

nias-o:projectHistory a owl:DatatypeProperty ;
    rdfs:label "projectHistory"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:string ;
    skos:definition "The history of the project and its activities."@en .

nias-o:projectParty a owl:ObjectProperty ;
    rdfs:label "projectParty"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range nias-o:ProjectParty ;
    skos:definition "A party associated with a project."@en .

nias-o:publicFundingSource a owl:DatatypeProperty ;
    rdfs:label "publicFundingSource"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:string ;
    skos:definition "A source of public funding for the project."@en .

nias-o:publicFundingStatus a owl:DatatypeProperty ;
    rdfs:label "publicFundingStatus"@en ;
    rdfs:domain aiao:Project ;
    rdfs:range xsd:boolean ;
    skos:definition "Indicates whether the project receives public funding."@en .

nias-o:publicPrivateClassification a owl:ObjectProperty ;
    rdfs:label "publicPrivateClassification"@en ;
    rdfs:domain nias-o:ProjectParty ;
    rdfs:range nias-o:PublicPrivateClassification ;
    skos:definition "Classifies a project party as public or private."@en .

nias-o:qaQcProcedures a owl:DatatypeProperty ;
    rdfs:label "qaQcProcedures"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:string ;
    skos:definition "Quality assurance and quality control procedures for a monitored data or parameter requirement."@en .

nias-o:resourceHederaMessageId a owl:ObjectProperty ;
    rdfs:label "hederaMessageId"@en ;
    rdfs:domain dcterms:Resource ;
    rdfs:range hedera:TopicMessage ;
    rdfs:subPropertyOf nias-o:resourceConsensusMessage ;
    owl:deprecated true ;
    skos:definition "Deprecated legacy property name. Use nias-o:resourceConsensusMessage to link the resource to the Hedera Consensus Service topic message that recorded publication, listing, or receipt."@en .

nias-o:resourceConsensusMessage a owl:ObjectProperty ;
    rdfs:label "resourceConsensusMessage"@en ;
    rdfs:domain dcterms:Resource ;
    rdfs:range hedera:TopicMessage ;
    skos:definition "The Hedera Consensus Service topic message that recorded publication, listing, or receipt of the resource."@en .

nias-o:resourceContentLocation a owl:DatatypeProperty ;
    rdfs:label "resourceContentLocation"@en ;
    rdfs:domain dcterms:Resource ;
    rdfs:range xsd:anyURI ;
    skos:definition "A resolvable URI where the content of a resource is available when it is not embedded directly in the RDF graph. Use nias-o:resourceIpfsUri for IPFS/IPNS content-addressed locations."@en .

nias-o:resourceIpfsUri a owl:DatatypeProperty ;
    rdfs:label "ipfsUri"@en ;
    rdfs:comment "If no value is provided for this property, the content of the resource should be provided directly or through nias-o:resourceContentLocation." ;
    rdfs:domain [ owl:unionOf ( dcterms:Resource impactont:SpatialLocation ) ] ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf nias-o:resourceContentLocation ;
    skos:definition "The IPFS URI, if any, of the resource in question."@en .

nias-o:reportStatus a owl:ObjectProperty ;
    rdfs:label "reportStatus"@en ;
    rdfs:domain claimont:Report ;
    rdfs:range nias-o:ReportStatus ;
    skos:definition "Status of a report version or estimate lifecycle (e.g., projected, measured, verified, revised)."@en .

nias-o:indicatorQualityDimension a owl:ObjectProperty ;
    rdfs:label "indicatorQualityDimension"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range nias-o:IndicatorQualityDimension ;
    skos:definition "A quality dimension used to assess an impact indicator."@en .

nias-o:instrumentQualityDimension a owl:ObjectProperty ;
    rdfs:label "instrumentQualityDimension"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range nias-o:InstrumentQualityDimension ;
    skos:definition "A quality dimension used to assess a measurement instrument."@en .

nias-o:methodologyQualityDimension a owl:ObjectProperty ;
    rdfs:label "methodologyQualityDimension"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range nias-o:MethodologyQualityDimension ;
    skos:definition "A quality dimension used to assess a methodology."@en .

nias-o:reputationLifecycleTerm a owl:ObjectProperty ;
    rdfs:label "reputationLifecycleTerm"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range nias-o:ReputationLifecycleTerm ;
    skos:definition "A reputation lifecycle term used in Knowledge and Skills Reputation rules."@en .

nias-o:reviewMandate a owl:ObjectProperty ;
    rdfs:label "reviewMandate"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range nias-o:ReviewMandate ;
    skos:definition "A review mandate such as validation or verification."@en .

nias-o:scoringModelTerm a owl:ObjectProperty ;
    rdfs:label "scoringModelTerm"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range nias-o:ScoringModelTerm ;
    skos:definition "A scoring model term used in NIAS activity scoring rules."@en .

nias-o:samplingPlan a owl:DatatypeProperty ;
    rdfs:label "samplingPlan"@en ;
    rdfs:domain nias-o:DataParameterRequirement ;
    rdfs:range xsd:string ;
    skos:definition "Sampling plan for a monitored data or parameter requirement."@en .

nias-o:techMeasType a owl:ObjectProperty ;
    rdfs:label "techMeasType"@en ;
    rdfs:domain nias-o:TechnologyOrMeasure ;
    rdfs:range nias-o:TechnologyMeasureType ;
    skos:definition "The subtype of a technology or measure to be implemented or employed by a project or an activity."@en .

nias-o:technologyOrMeasure a owl:ObjectProperty ;
    rdfs:label "technologyOrMeasure"@en ;
    rdfs:domain [ owl:unionOf ( aiao:Activity aiao:Project ) ] ;
    rdfs:range nias-o:TechnologyOrMeasure ;
    skos:definition "The technology or measures to be implemented or employed by a project or an activity."@en .

nias-o:title a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:domain [ owl:unionOf ( aiao:Activity aiao:Project ) ] ;
    rdfs:range xsd:string ;
    skos:definition "A human-friendly title for an activity or project."@en .

nias-o:approvalStatus a owl:ObjectProperty ;
    rdfs:label "approvalStatus"@en ;
    rdfs:domain meth:Methodology ;
    rdfs:range nias-o:MethodologyApprovalStatus ;
    skos:definition "The approval status of a methodology within the Nova Impact Accounting Standard (e.g., proposed, under evaluation, approved, rejected, surpassed, deprecated)."@en .

nias-o:requiresKnowledgeDomain a owl:ObjectProperty ;
    rdfs:label "requiresKnowledgeDomain"@en ;
    rdfs:domain meth:Methodology ;
    rdfs:range skos:Concept ;
    skos:definition "A knowledge domain that validators or verifiers must possess in order to evaluate a methodology."@en .

nias-o:usesMethodology a owl:ObjectProperty ;
    rdfs:label "usesMethodology"@en ;
    rdfs:domain [ owl:unionOf ( claimont:Claim claimont:Report ) ] ;
    rdfs:range meth:Methodology ;
    skos:definition "Identifies the methodology used as the basis for a claim or report, including an aiao:ImpactClaim about an aiao:Project or a nias-o:ProjectDesignDocument."@en .

nias-o:unitOfMeasure a owl:ObjectProperty ;
    rdfs:label "unitOfMeasure"@en ;
    rdfs:domain impactont:Indicator ;
    rdfs:range qudt:Unit ;
    skos:definition "A unit of measure, referenced as a QUDT unit IRI."@en .

nias-o:workflow a owl:ObjectProperty ;
    rdfs:label "workflow"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:WorkflowDocumentSubmission nias-o:AgentActivityWorkflowRelation ) ] ;
    rdfs:range nias-o:Workflow ;
    skos:definition "The workflow to which a document was submitted, or in the context of which an agent-activity relation exists."@en .

nias-o:workflowDocumentSubmissionHederaMessageId a owl:ObjectProperty ;
    rdfs:label "hederaMessageId"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range hedera:TopicMessage ;
    rdfs:subPropertyOf nias-o:workflowSubmissionConsensusMessage ;
    owl:deprecated true ;
    skos:definition "Deprecated legacy property name. Use nias-o:workflowSubmissionConsensusMessage to link a workflow document submission to the Hedera Consensus Service topic message that recorded it."@en .

nias-o:workflowSubmissionConsensusMessage a owl:ObjectProperty ;
    rdfs:label "workflowSubmissionConsensusMessage"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range hedera:TopicMessage ;
    skos:definition "The Hedera Consensus Service topic message that recorded a workflow document submission."@en .

nias-o:submittedDocument a owl:ObjectProperty ;
    rdfs:label "submittedDocument"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range data:Document ;
    rdfs:subPropertyOf infocomm:transmits ;
    owl:inverseOf nias-o:hasWorkflowSubmission ;
    skos:definition "The document transmitted by a workflow document submission communication event."@en .

nias-o:workflowDocumentSubmittedBy a owl:ObjectProperty ;
    rdfs:label "submittedBy"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range nias-o:PlatformUser ;
    rdfs:subPropertyOf infocomm:hasSender ;
    skos:definition "The platform user who submitted the document."@en .

nias-o:workflowDocumentRecipient a owl:ObjectProperty ;
    rdfs:label "workflowDocumentRecipient"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range infocomm:CommunicationParty ;
    rdfs:subPropertyOf infocomm:hasRecipient ;
    skos:definition "The platform, registry, workflow endpoint, or agent that receives a workflow document submission."@en .

nias-o:workflowStep a owl:ObjectProperty ;
    rdfs:label "workflowStep"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range nias-o:WorkflowStep ;
    skos:definition "The workflow step to which the document was submitted."@en .

nias-o:workflowSubject a owl:ObjectProperty ;
    rdfs:label "workflowSubject"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range owl:Thing ;
    skos:definition "The subject of the workflow in respect of which or whom the document was submitted."@en .

nias-o:implementationPlan a owl:ObjectProperty ;
    rdfs:label "implementationPlan"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:ProjectDesignDocument aiao:Project ) ] ;
    rdfs:range prov:Plan ;
    skos:definition "Links a project design document or project to a plan for future implementation activities. Use only where the PDD describes intended future implementation steps; do not type the PDD itself as prov:Plan."@en .

nias-o:monitoringPlan a owl:ObjectProperty ;
    rdfs:label "monitoringPlan"@en ;
    rdfs:domain [ owl:unionOf ( nias-o:ProjectDesignDocument aiao:Project ) ] ;
    rdfs:range prov:Plan ;
    skos:definition "Links a project design document or project to a monitoring plan for future measurement procedures. Use only where the PDD describes intended future monitoring steps."@en .

nias-o:reportContent a owl:ObjectProperty ;
    rdfs:label "reportContent"@en ;
    rdfs:domain data:Document ;
    rdfs:range claimont:Report ;
    skos:definition "Links a document artifact to the report content asserted within it, separating the document metadata carrier from the agent-authored claim/report layer."@en .

nias-o:stateClaim a owl:ObjectProperty ;
    rdfs:label "stateClaim"@en ;
    rdfs:domain claimont:Report ;
    rdfs:range aiao:StateClaim ;
    skos:definition "Links a report to a state claim about the project or activity."@en .

nias-o:stateProvenanceClaim a owl:ObjectProperty ;
    rdfs:label "stateProvenanceClaim"@en ;
    rdfs:domain claimont:Report ;
    rdfs:range aiao:StateProvenanceClaim ;
    skos:definition "Links a report to a state provenance claim, providing evidential justification for a state value."@en .

# Agent details and license classes

nias-o:AgentDetails a owl:Class ;
    rdfs:label "AgentDetails"@en ;
    rdfs:subClassOf nias-o:PlatformUser ;
    skos:definition "A platform user record created from a submitted agent details form, carrying identity and Hedera account registration data alongside the workflow submission."@en .

nias-o:LicenseApplication a owl:Class ;
    rdfs:label "LicenseApplication"@en ;
    skos:definition "A submitted application by a platform user to be granted an Independent Impact agent license for a specific role."@en .

nias-o:LicenseApplicationReview a owl:Class ;
    rdfs:label "LicenseApplicationReview"@en ;
    rdfs:subClassOf nias-o:DocumentReview ;
    skos:definition "A review document recording the approval or rejection of a license application, referencing the prior agent details review."@en .

nias-o:ProjectRegistrationRequest a owl:Class ;
    rdfs:label "ProjectRegistrationRequest"@en ;
    skos:definition "A request submitted by a project developer to formally register a project after the associated PDD certificate issuance request has been approved."@en .

nias-o:MethodologyApplicability a owl:Class ;
    rdfs:label "MethodologyApplicability"@en ;
    skos:definition "A node recording that a specific methodology is applicable to a use case and stating the rationale for that applicability."@en .

# Agent details properties

nias-o:initials a owl:DatatypeProperty ;
    rdfs:label "initials"@en ;
    rdfs:domain nias-o:AgentDetails ;
    rdfs:range xsd:string ;
    skos:definition "The initials of the agent as provided in the agent details registration form."@en .

nias-o:supportingEvidencePersonalParticulars a owl:ObjectProperty ;
    rdfs:label "supportingEvidencePersonalParticulars"@en ;
    rdfs:domain nias-o:AgentDetails ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "A supporting evidence artifact for the agent's personal particulars (initials, name, date of birth, country of residence). Up to two evidence artifacts may be provided."@en .

nias-o:supportingEvidenceEmail a owl:ObjectProperty ;
    rdfs:label "supportingEvidenceEmail"@en ;
    rdfs:domain nias-o:AgentDetails ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "A supporting evidence artifact proving ownership of the agent's registered email address."@en .

nias-o:supportingEvidenceContactNumber a owl:ObjectProperty ;
    rdfs:label "supportingEvidenceContactNumber"@en ;
    rdfs:domain nias-o:AgentDetails ;
    rdfs:range nias-o:ResourceArtifact ;
    skos:definition "A supporting evidence artifact proving ownership of the agent's registered contact number."@en .

# License application and review properties

nias-o:reviewerCommentary a owl:DatatypeProperty ;
    rdfs:label "reviewerCommentary"@en ;
    rdfs:domain nias-o:LicenseApplicationReview ;
    rdfs:range xsd:string ;
    skos:definition "Free-text commentary provided by the reviewer in a license application review."@en .

nias-o:agentDetailsReview a owl:ObjectProperty ;
    rdfs:label "agentDetailsReview"@en ;
    rdfs:domain nias-o:LicenseApplicationReview ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Reference to the approved agent details review document that preceded this license application review."@en .

# Issued agent license properties

nias-o:licenseeDid a owl:DatatypeProperty ;
    rdfs:label "licenseeDid"@en ;
    rdfs:domain nias-o:AgentLicense ;
    rdfs:range xsd:string ;
    skos:definition "The decentralized identifier (DID) of the holder of the issued agent license."@en .

# Project registration request properties

nias-o:approvedPddCertificateIssuanceRequest a owl:ObjectProperty ;
    rdfs:label "approvedPddCertificateIssuanceRequest"@en ;
    rdfs:domain nias-o:ProjectRegistrationRequest ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Reference to the approved PDD certificate issuance request review that authorises project registration."@en .

# Methodology applicability properties

nias-o:applicabilityRationale a owl:DatatypeProperty ;
    rdfs:label "applicabilityRationale"@en ;
    rdfs:domain nias-o:MethodologyApplicability ;
    rdfs:range xsd:string ;
    skos:definition "Textual rationale explaining why the referenced methodology is applicable to the quantification use case."@en .

nias-o:indicatorMethodologyApplicability a owl:ObjectProperty ;
    rdfs:label "indicatorMethodologyApplicability"@en ;
    rdfs:range nias-o:MethodologyApplicability ;
    skos:definition "Links an impact or impact declaration to a methodology applicability node that carries both the methodology reference and the applicability rationale."@en .

# Legacy workflow document header properties

nias-o:submitterLicense a owl:ObjectProperty ;
    rdfs:label "submitterLicense"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Optional reference to the relevant agent license of the person who submitted the workflow document. Legacy document header field."@en .

nias-o:predecessorDocument a owl:ObjectProperty ;
    rdfs:label "predecessorDocument"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    rdfs:range nias-o:DocumentReference ;
    skos:definition "Optional reference to the document that logically preceded this workflow document submission. Legacy document header field."@en .

nias-o:workflowSubjectType a owl:ObjectProperty ;
    rdfs:label "workflowSubjectType"@en ;
    rdfs:domain nias-o:WorkflowDocumentSubmission ;
    skos:definition "Optional legacy discriminator indicating whether the workflow subject is a project or an agent. In the canonical model this is implicit from the workflowSubject IRI."@en .
