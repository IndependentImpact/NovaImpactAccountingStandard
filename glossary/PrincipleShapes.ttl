@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nias-o:PrincipleShapes a owl:Ontology ;
    dcterms:title "Nova Impact Accounting Standard - Principle concept scheme SHACL shapes"@en ;
    dcterms:description "SHACL shapes validating the ImpactPrinciple and AccountingPrinciple concept schemes defined in Principle.ttl."@en .

# ---------------------------------------------------------------------------
# Shared concept shape: every skos:Concept must carry prefLabel and definition
# ---------------------------------------------------------------------------

nias-o:SkosConceptRequiredFieldsShape a sh:NodeShape ;
    sh:targetClass skos:Concept ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Every skos:Concept must have at least one skos:prefLabel."@en ;
    ] ;
    sh:property [
        sh:path skos:definition ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Every skos:Concept must have at least one skos:definition."@en ;
    ] ;
    sh:property [
        sh:path skos:inScheme ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:message "Every skos:Concept must reference at least one skos:ConceptScheme via skos:inScheme."@en ;
    ] .

# ---------------------------------------------------------------------------
# Shared concept scheme shape: every skos:ConceptScheme must carry prefLabel and definition
# ---------------------------------------------------------------------------

nias-o:SkosConceptSchemeRequiredFieldsShape a sh:NodeShape ;
    sh:targetClass skos:ConceptScheme ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Every skos:ConceptScheme must have at least one skos:prefLabel."@en ;
    ] ;
    sh:property [
        sh:path skos:definition ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Every skos:ConceptScheme must have at least one skos:definition."@en ;
    ] ;
    sh:property [
        sh:path skos:hasTopConcept ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:message "Every skos:ConceptScheme must declare at least one top concept via skos:hasTopConcept."@en ;
    ] .

# ---------------------------------------------------------------------------
# ImpactPrinciple membership shape
# ---------------------------------------------------------------------------

nias-o:ImpactPrincipleMemberShape a sh:NodeShape ;
    sh:targetObjectsOf skos:hasTopConcept ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Concept is not a member of the ImpactPrinciple concept scheme."@en ;
        sh:prefixes [
            sh:declare [
                sh:prefix "skos" ;
                sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI ;
            ] ;
            sh:declare [
                sh:prefix "nias-cs" ;
                sh:namespace "https://nova.org.za/novaimpactaccountingstandard/"^^xsd:anyURI ;
            ] ;
        ] ;
        sh:select """
            SELECT $this WHERE {
                nias-cs:ImpactPrinciple skos:hasTopConcept $this .
                FILTER NOT EXISTS { $this skos:inScheme nias-cs:ImpactPrinciple }
            }
        """ ;
    ] .

# ---------------------------------------------------------------------------
# AccountingPrinciple membership shape
# ---------------------------------------------------------------------------

nias-o:AccountingPrincipleMemberShape a sh:NodeShape ;
    sh:targetObjectsOf skos:hasTopConcept ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Concept is not a member of the AccountingPrinciple concept scheme."@en ;
        sh:prefixes [
            sh:declare [
                sh:prefix "skos" ;
                sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI ;
            ] ;
            sh:declare [
                sh:prefix "nias-cs" ;
                sh:namespace "https://nova.org.za/novaimpactaccountingstandard/"^^xsd:anyURI ;
            ] ;
        ] ;
        sh:select """
            SELECT $this WHERE {
                nias-cs:AccountingPrinciple skos:hasTopConcept $this .
                FILTER NOT EXISTS { $this skos:inScheme nias-cs:AccountingPrinciple }
            }
        """ ;
    ] .

# ---------------------------------------------------------------------------
# Property shapes: ready-to-reference sh:in lists for use in future NodeShapes
# ---------------------------------------------------------------------------

nias-o:ImpactPrincipleValueShape a sh:PropertyShape ;
    sh:path nias-o:impactPrinciple ;
    sh:class skos:Concept ;
    sh:in (
        nias-cs:purposefulness
        nias-cs:do-no-harm
        nias-cs:impact-effectiveness
        nias-cs:impact-efficiency
        nias-cs:equity-and-inclusivity
        nias-cs:adaptiveness
    ) ;
    sh:message "The value of nias-o:impactPrinciple must be a recognised ImpactPrinciple concept."@en .

nias-o:AccountingPrincipleValueShape a sh:PropertyShape ;
    sh:path nias-o:accountingPrinciple ;
    sh:class skos:Concept ;
    sh:in (
        nias-cs:accounting-relevance
        nias-cs:accounting-completeness
        nias-cs:accounting-consistency
        nias-cs:accounting-accuracy
        nias-cs:accounting-conservativeness
        nias-cs:accounting-verifiability
        nias-cs:accounting-accountability
    ) ;
    sh:message "The value of nias-o:accountingPrinciple must be a recognised AccountingPrinciple concept."@en .
