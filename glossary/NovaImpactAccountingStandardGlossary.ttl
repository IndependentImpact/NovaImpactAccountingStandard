@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

nias-cs:adverse a skos:Concept ;
    skos:definition "Impact that has an adverse environmental effect." ;
    skos:inScheme nias-cs:BeneficialOrAdverse ;
    skos:prefLabel "Adverse" ;
    skos:topConceptOf nias-cs:BeneficialOrAdverse .

nias-cs:beneficial a skos:Concept ;
    skos:definition "Impact that has a beneficial environmental effect." ;
    skos:inScheme nias-cs:BeneficialOrAdverse ;
    skos:prefLabel "Beneficial" ;
    skos:topConceptOf nias-cs:BeneficialOrAdverse .

nias-cs:eddsa-signature a skos:Concept ;
    skos:definition "Authenticity proven via an EdDSA digital signature." ;
    skos:inScheme nias-cs:AuthProof ;
    skos:prefLabel "EdDSA signature" ;
    skos:topConceptOf nias-cs:AuthProof .

nias-cs:equipment a skos:Concept ;
    skos:definition "Technology or measure that is specific equipment." ;
    skos:inScheme nias-cs:TechMeasType ;
    skos:prefLabel "Equipment" ;
    skos:topConceptOf nias-cs:TechMeasType .

nias-cs:facility a skos:Concept ;
    skos:definition "Technology or measure that is categorized as a facility." ;
    skos:inScheme nias-cs:TechMeasType ;
    skos:prefLabel "Facility" ;
    skos:topConceptOf nias-cs:TechMeasType .

nias-cs:intentional a skos:Concept ;
    skos:definition "Impact that was deliberately intended." ;
    skos:inScheme nias-cs:ImpactIntentionality ;
    skos:prefLabel "Intentional" ;
    skos:topConceptOf nias-cs:ImpactIntentionality .

nias-cs:fixed-ex-ante a skos:Concept ;
    skos:definition "Parameter or data point whose value is determined and fixed prior to the start of the crediting period." ;
    skos:inScheme nias-cs:MonitoredOrFixed ;
    skos:prefLabel "Fixed ex-ante" ;
    skos:topConceptOf nias-cs:MonitoredOrFixed .

nias-cs:monitored a skos:Concept ;
    skos:definition "Parameter or data point whose value is determined through ongoing monitoring during the crediting period." ;
    skos:inScheme nias-cs:MonitoredOrFixed ;
    skos:prefLabel "Monitored" ;
    skos:topConceptOf nias-cs:MonitoredOrFixed .

nias-cs:mr-verifier a skos:Concept ;
    skos:definition "License scope permitting verification of monitoring reports." ;
    skos:inScheme nias-cs:LicenseScope ;
    skos:prefLabel "MR verifier" ;
    skos:topConceptOf nias-cs:LicenseScope .

nias-cs:no a skos:Concept ;
    skos:definition "Impact will not be monitored." ;
    skos:inScheme nias-cs:MonitoringStatus ;
    skos:prefLabel "No" ;
    skos:topConceptOf nias-cs:MonitoringStatus .

nias-cs:none a skos:Concept ;
    skos:definition "No authenticity proof is provided." ;
    skos:inScheme nias-cs:AuthProof ;
    skos:prefLabel "None" ;
    skos:topConceptOf nias-cs:AuthProof .

nias-cs:other a skos:Concept ;
    skos:definition "Technology or measure subtype not captured by the other categories." ;
    skos:inScheme nias-cs:TechMeasType ;
    skos:prefLabel "Other" ;
    skos:topConceptOf nias-cs:TechMeasType .

nias-cs:pdd-validator a skos:Concept ;
    skos:definition "License scope permitting validation of project design documents." ;
    skos:inScheme nias-cs:LicenseScope ;
    skos:prefLabel "PDD validator" ;
    skos:topConceptOf nias-cs:LicenseScope .

nias-cs:project-developer a skos:Concept ;
    skos:definition "License scope permitting project development activities." ;
    skos:inScheme nias-cs:LicenseScope ;
    skos:prefLabel "Project developer" ;
    skos:topConceptOf nias-cs:LicenseScope .

nias-cs:rsa-signature a skos:Concept ;
    skos:definition "Authenticity proven via an RSA digital signature." ;
    skos:inScheme nias-cs:AuthProof ;
    skos:prefLabel "RSA signature" ;
    skos:topConceptOf nias-cs:AuthProof .

nias-cs:system a skos:Concept ;
    skos:definition "Technology or measure that operates as a system." ;
    skos:inScheme nias-cs:TechMeasType ;
    skos:prefLabel "System" ;
    skos:topConceptOf nias-cs:TechMeasType .

nias-cs:unintentional a skos:Concept ;
    skos:definition "Impact that occurred without being deliberately intended." ;
    skos:inScheme nias-cs:ImpactIntentionality ;
    skos:prefLabel "Unintentional" ;
    skos:topConceptOf nias-cs:ImpactIntentionality .

nias-cs:vc a skos:Concept ;
    skos:definition "Authenticity proven via a verifiable credential." ;
    skos:inScheme nias-cs:AuthProof ;
    skos:prefLabel "Verifiable credential" ;
    skos:topConceptOf nias-cs:AuthProof .

nias-cs:yes a skos:Concept ;
    skos:definition "Impact will be monitored." ;
    skos:inScheme nias-cs:MonitoringStatus ;
    skos:prefLabel "Yes" ;
    skos:topConceptOf nias-cs:MonitoringStatus .

nias-cs:BeneficialOrAdverse a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether an impact is beneficial or adverse." ;
    skos:hasTopConcept nias-cs:adverse,
        nias-cs:beneficial ;
    skos:prefLabel "Impact benefit classification" .

nias-cs:ImpactIntentionality a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether an impact was intentional or unintentional." ;
    skos:hasTopConcept nias-cs:intentional,
        nias-cs:unintentional ;
    skos:prefLabel "Impact intentionality" .

nias-cs:MonitoringStatus a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether an impact will be monitored." ;
    skos:hasTopConcept nias-cs:no,
        nias-cs:yes ;
    skos:prefLabel "Impact monitoring status" .

nias-cs:LicenseScope a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary of scopes for Nova Impact Accounting Standard Agent Licenses." ;
    skos:hasTopConcept nias-cs:mr-verifier,
        nias-cs:pdd-validator,
        nias-cs:project-developer ;
    skos:prefLabel "Nova Impact Accounting Standard license scopes" .

nias-cs:AuthProof a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary describing how document authenticity is proven." ;
    skos:hasTopConcept nias-cs:eddsa-signature,
        nias-cs:none,
        nias-cs:rsa-signature,
        nias-cs:vc ;
    skos:prefLabel "Document authenticity proof mechanisms" .

nias-cs:TechMeasType a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary for subtypes of technologies or measures used in projects or activities." ;
    skos:hasTopConcept nias-cs:equipment,
        nias-cs:facility,
        nias-cs:other,
        nias-cs:system ;
    skos:prefLabel "Technology or measure subtypes" .

nias-cs:MonitoredOrFixed a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary indicating whether a data parameter will be monitored during the crediting period or fixed ex-ante." ;
    skos:hasTopConcept nias-cs:fixed-ex-ante,
        nias-cs:monitored ;
    skos:prefLabel "Monitored or fixed ex-ante" .

nias-cs:proposed a skos:Concept ;
    skos:definition "Methodology has been submitted for consideration but has not yet entered formal evaluation." ;
    skos:inScheme nias-cs:MethodologyApprovalStatus ;
    skos:prefLabel "Proposed" ;
    skos:topConceptOf nias-cs:MethodologyApprovalStatus .

nias-cs:under-evaluation a skos:Concept ;
    skos:definition "Methodology is currently undergoing formal technical evaluation and review." ;
    skos:inScheme nias-cs:MethodologyApprovalStatus ;
    skos:prefLabel "Under evaluation" ;
    skos:topConceptOf nias-cs:MethodologyApprovalStatus .

nias-cs:approved a skos:Concept ;
    skos:definition "Methodology has passed formal evaluation and is approved for use under the standard." ;
    skos:inScheme nias-cs:MethodologyApprovalStatus ;
    skos:prefLabel "Approved" ;
    skos:topConceptOf nias-cs:MethodologyApprovalStatus .

nias-cs:rejected a skos:Concept ;
    skos:definition "Methodology was evaluated and rejected; it may not be used under the standard." ;
    skos:inScheme nias-cs:MethodologyApprovalStatus ;
    skos:prefLabel "Rejected" ;
    skos:topConceptOf nias-cs:MethodologyApprovalStatus .

nias-cs:surpassed a skos:Concept ;
    skos:definition "Methodology has been superseded by a newer or improved version; projects should migrate to the replacement." ;
    skos:inScheme nias-cs:MethodologyApprovalStatus ;
    skos:prefLabel "Surpassed" ;
    skos:topConceptOf nias-cs:MethodologyApprovalStatus .

nias-cs:deprecated a skos:Concept ;
    skos:definition "Methodology is no longer recommended for new projects; existing registered projects may continue to use it." ;
    skos:inScheme nias-cs:MethodologyApprovalStatus ;
    skos:prefLabel "Deprecated" ;
    skos:topConceptOf nias-cs:MethodologyApprovalStatus .

nias-cs:MethodologyApprovalStatus a skos:ConceptScheme ;
    skos:definition "Controlled vocabulary describing the approval status of a methodology within the Nova Impact Accounting Standard." ;
    skos:hasTopConcept nias-cs:approved,
        nias-cs:deprecated,
        nias-cs:proposed,
        nias-cs:rejected,
        nias-cs:surpassed,
        nias-cs:under-evaluation ;
    skos:prefLabel "Methodology approval status" .

