@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix nias-cs: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-o: <https://nova.org.za/novaimpactaccountingstandard/> .
@prefix nias-vvs: <https://nova.org.za/novaimpactaccountingstandard/vvs/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ---------------------------------------------------------------------------
# Validation & Verification Standard (VVS) - requirement graph
# ---------------------------------------------------------------------------

<https://nova.org.za/novaimpactaccountingstandard/vvs/> a owl:Ontology ;
    rdfs:label "Nova Impact Accounting Standard — Validation & Verification Standard"@en ;
    dcterms:title "NIAS Validation & Verification Standard Requirements"@en ;
    dcterms:description "Requirement instances for the NIAS Validation & Verification Standard (VVS). Each resource carries a stable IRI, human-readable identifier, mandate, status, and links to the anchor artifact class at which the requirement is assessed."@en .

# ---------------------------------------------------------------------------
# Requirement status concept scheme
# ---------------------------------------------------------------------------

nias-vvs:RequirementStatus a skos:ConceptScheme ;
    skos:prefLabel "Requirement status"@en ;
    skos:definition "Controlled lifecycle statuses for VVS requirement resources."@en ;
    skos:hasTopConcept nias-vvs:draft, nias-vvs:active, nias-vvs:deprecated .

nias-vvs:draft a skos:Concept ;
    skos:inScheme nias-vvs:RequirementStatus ;
    skos:topConceptOf nias-vvs:RequirementStatus ;
    skos:prefLabel "Draft"@en ;
    skos:definition "The requirement is under development and has not yet been formally adopted."@en .

nias-vvs:active a skos:Concept ;
    skos:inScheme nias-vvs:RequirementStatus ;
    skos:topConceptOf nias-vvs:RequirementStatus ;
    skos:prefLabel "Active"@en ;
    skos:definition "The requirement is formally adopted and currently in force."@en .

nias-vvs:deprecated a skos:Concept ;
    skos:inScheme nias-vvs:RequirementStatus ;
    skos:topConceptOf nias-vvs:RequirementStatus ;
    skos:prefLabel "Deprecated"@en ;
    skos:definition "The requirement has been superseded and is no longer in force."@en .

# ---------------------------------------------------------------------------
# Pilot requirements — Phase 1
# ---------------------------------------------------------------------------

# REQ-PDD-001 — PDD-A structural content
nias-vvs:REQ-PDD-001 a nias-o:ValidationRequirement ;
    nias-o:requirementId "REQ-PDD-001" ;
    nias-o:reviewMandate nias-cs:validation ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:validatedAt nias-o:PddSectionAReport ;
    nias-o:implementedByShape nias-o:ReqPdd001Shape ;
    rdfs:label "REQ-PDD-001: PDD Section A structural completeness"@en ;
    skos:definition "A PDD Section A report must declare the project title, the project developer agent, and at least one project activity. All mandatory structural fields must be present and non-empty."@en .

# REQ-PDD-002 — PDD-B impact declaration
nias-vvs:REQ-PDD-002 a nias-o:ValidationRequirement ;
    nias-o:requirementId "REQ-PDD-002" ;
    nias-o:reviewMandate nias-cs:validation ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:validatedAt nias-o:PddSectionBReport ;
    nias-o:implementedByShape nias-o:ReqPdd002Shape ;
    rdfs:label "REQ-PDD-002: PDD Section B impact declaration completeness"@en ;
    skos:definition "Each impact declared in PDD Section B must reference a quantification methodology, declare an impact benefit classification, and include an estimated impact quantity with a unit of measurement."@en .

# REQ-PDD-003 — PDD-C schema anchoring
nias-vvs:REQ-PDD-003 a nias-o:ValidationRequirement ;
    nias-o:requirementId "REQ-PDD-003" ;
    nias-o:reviewMandate nias-cs:validation ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:validatedAt nias-o:PddSectionCReport ;
    nias-o:verifiedBy nias-o:MonitoringReport ;
    nias-o:implementedByShape nias-o:ReqPdd003Shape ;
    rdfs:label "REQ-PDD-003: PDD Section C schema conformance"@en ;
    skos:definition "A PDD Section C report must identify the canonical PDDxC document schema to ensure implementation and monitoring planning content is versioned against the approved standard form."@en .

# REQ-DLR-001 — DLR evidence lineage
nias-vvs:REQ-DLR-001 a nias-o:VerificationRequirement ;
    nias-o:requirementId "REQ-DLR-001" ;
    nias-o:reviewMandate nias-cs:verification ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:verifiedBy nias-o:DataLineageReport ;
    nias-o:implementedByShape nias-o:ReqDlr001Shape ;
    rdfs:label "REQ-DLR-001: Data Lineage Report evidence traceability"@en ;
    skos:definition "Every data parameter recorded in a Data Lineage Report must include a traceable provenance reference linking the measured value to its source dataset and collection method."@en .

# REQ-DLR-002 — DLR final dataset traceability
nias-vvs:REQ-DLR-002 a nias-o:VerificationRequirement ;
    nias-o:requirementId "REQ-DLR-002" ;
    nias-o:reviewMandate nias-cs:verification ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:validatedAt nias-o:PddSectionBReport ;
    nias-o:verifiedBy nias-o:DataLineageReport ;
    nias-o:implementedByShape nias-o:ReqDlr002Shape ;
    rdfs:label "REQ-DLR-002: Data Lineage Report final dataset artifact"@en ;
    skos:definition "A Data Lineage Report must reference a final dataset artifact so that post-cleaning and post-transfer outputs remain auditable for downstream verification and issuance workflows."@en .

# REQ-MR-001 — MR measured observation
nias-vvs:REQ-MR-001 a nias-o:VerificationRequirement ;
    nias-o:requirementId "REQ-MR-001" ;
    nias-o:reviewMandate nias-cs:verification ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:verifiedBy nias-o:MonitoringReport ;
    nias-o:implementedByShape nias-o:ReqMr001Shape ;
    rdfs:label "REQ-MR-001: Monitoring Report measured impact observation"@en ;
    skos:definition "Each measured impact in a Monitoring Report must reference the corresponding PDD Section B impact declaration and record an observed impact quantity with a consistent unit of measurement."@en .

# REQ-MR-002 — MR issuance target declaration
nias-vvs:REQ-MR-002 a nias-o:VerificationRequirement ;
    nias-o:requirementId "REQ-MR-002" ;
    nias-o:reviewMandate nias-cs:verification ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:validatedAt nias-o:PddSectionBReport ;
    nias-o:verifiedBy nias-o:MonitoringReport ;
    nias-o:implementedByShape nias-o:ReqMr002Shape ;
    rdfs:label "REQ-MR-002: Monitoring Report issuance account declaration"@en ;
    skos:definition "A Monitoring Report must declare the requested issuance account identifier so verified impact outcomes can be linked to the intended issuance destination in a deterministic way."@en .

# REQ-CROSS-001 — Cross-artifact traceability
nias-vvs:REQ-CROSS-001 a nias-o:VerificationRequirement ;
    nias-o:requirementId "REQ-CROSS-001" ;
    nias-o:reviewMandate nias-cs:verification ;
    nias-o:requirementStatus nias-vvs:active ;
    nias-o:validatedAt nias-o:PddSectionBReport ;
    nias-o:verifiedBy nias-o:MonitoringReport ;
    nias-o:implementedByShape nias-o:ReqCross001Shape ;
    rdfs:label "REQ-CROSS-001: Cross-artifact impact traceability"@en ;
    skos:definition "Every measured impact reported in a Monitoring Report must be traceable to an impact declared in the corresponding validated PDD, enabling end-to-end traceability from ex-ante declaration to ex-post measurement."@en .
